# ============================================================
# CONFIGURACIÓN DE BASE DE DATOS
# ============================================================
DATABASE_URL="postgresql://username:password@localhost:5432/erp_rh"

# ============================================================
# CONFIGURACIÓN DE DOCKER POSTGRES
# ============================================================
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=erp_password
POSTGRES_DB=erp_rh
DB_PORT=5432

# ============================================================
# CONFIGURACIÓN DE SERVIDOR
# ============================================================
PORT=3001
# Usa production en servidor/despliegue y development en local
NODE_ENV=production
HOST=0.0.0.0
# HSTS solo si ya tienes HTTPS funcionando (Nginx/SSL)
ENABLE_HSTS=false
CSP_UPGRADE_INSECURE_REQUESTS=false
# Forzar cookie secure=true (requiere HTTPS). En HTTP, usar false.
SESSION_COOKIE_SECURE=false

# ============================================================
# CONFIGURACIÓN DE SESIÓN
# ============================================================
SESSION_SECRET=your_secret_key_here

# ============================================================
# CONFIGURACIÓN DE APLICACIÓN
# ============================================================
APP_NAME="ERP - Gestión de Recursos Humanos"
APP_URL="http://localhost:3001"

# ============================================================
# CONFIGURACIÓN DE API BIOMÉTRICA
# ============================================================
# API Key para autenticación de dispositivos biométricos
# Generar una clave segura y única para producción
BIOMETRIC_API_KEY=ram-biometric-key-2024

# ============================================================
# ADMS - PUSH DIRECTO DE CHECADORES (CLK-980 / protocolo ZK)
# ============================================================
# Activa/desactiva los endpoints /iclock/* sin redeploy (false => 404)
ADMS_ENABLED=true
# Umbral de desfase de reloj device vs servidor (min) para encolar SET_TIME
ADMS_TIME_DRIFT_MAX_MIN=5
# Ventana de deduplicación heurística en segundos (0 = OFF; la idempotencia por hash siempre aplica)
ADMS_DEDUP_WINDOW_SEC=0
# Máximo de devices auto-descubiertos en estado pendiente_aprobacion (anti-flood)
ADMS_PENDIENTES_MAX=10
# TimeZone que se envía al device en el handshake (offset GMT). México centro = -6
ADMS_TIMEZONE=-6
