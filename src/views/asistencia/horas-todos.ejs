<%
function fmtH(n){ if(n==null) return '-'; const h=Math.floor(n); const m=Math.round((n-h)*60); if(h===0&&m===0) return '0'; if(h===0) return m+'m'; if(m===0) return h+'h'; return h+'h '+m+'m'; }
%>
<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 gap-2">
  <div>
    <h4 class="mb-1">Consultar Horas</h4>
    <p class="text-body-secondary mb-0">Horas trabajadas por empleado (checadas en vivo). Clic en un empleado para el desglose diario.</p>
  </div>
  <a href="/checador" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-file-earmark-spreadsheet me-1"></i>Importar XLSX (respaldo)
  </a>
</div>

<!-- Filtro -->
<form method="GET" class="card mb-4">
  <div class="card-body d-flex flex-wrap gap-3 align-items-end">
    <div>
      <label class="form-label small mb-1">Desde</label>
      <input type="date" name="fechaInicio" value="<%= fechaInicio %>" class="form-control form-control-sm">
    </div>
    <div>
      <label class="form-label small mb-1">Hasta</label>
      <input type="date" name="fechaFin" value="<%= fechaFin %>" class="form-control form-control-sm">
    </div>
    <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-funnel me-1"></i>Filtrar</button>
    <span class="text-body-secondary small ms-auto align-self-center">
      Periodo: <%= new Date(datos.periodo.fechaInicio).toLocaleDateString('es-MX') %> – <%= new Date(datos.periodo.fechaFin).toLocaleDateString('es-MX') %>
    </span>
  </div>
</form>

<!-- Tabla -->
<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th>Empleado</th>
            <th>Área</th>
            <th class="text-center">Días</th>
            <th class="text-end">Normales</th>
            <th class="text-end">Extras</th>
            <th class="text-end">Total</th>
            <th class="text-end">Faltantes</th>
            <th class="text-center">Retardos</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% if (datos.filas && datos.filas.length > 0) { %>
            <% datos.filas.forEach(function(f) { %>
            <tr class="<%= f.horas === 0 ? 'text-body-secondary' : '' %>">
              <td>
                <a href="/asistencia/horas/<%= f.ID_Empleado %>?fechaInicio=<%= fechaInicio %>&fechaFin=<%= fechaFin %>" class="text-decoration-none fw-semibold">
                  <%= f.nombre %>
                </a>
                <% if (f.multi > 0) { %><span class="badge bg-info ms-1" title="<%= f.multi %> día(s) multi-planta">multi</span><% } %>
                <div class="small text-body-secondary"><%= f.puesto %></div>
              </td>
              <td class="small"><%= f.area %></td>
              <td class="text-center"><%= f.dias %></td>
              <td class="text-end"><%= fmtH(f.normales) %></td>
              <td class="text-end"><%= f.extras > 0 ? fmtH(f.extras) : '-' %></td>
              <td class="text-end fw-bold"><%= fmtH(f.horas) %></td>
              <td class="text-end <%= f.faltantes > 0 ? 'text-danger' : 'text-success' %>">
                <%= f.faltantes > 0 ? fmtH(f.faltantes) : '✓' %>
              </td>
              <td class="text-center"><%= f.retardos > 0 ? f.retardos : '-' %></td>
              <td class="text-end">
                <a href="/asistencia/horas/<%= f.ID_Empleado %>?fechaInicio=<%= fechaInicio %>&fechaFin=<%= fechaFin %>" class="btn btn-sm btn-outline-primary" title="Desglose diario">
                  <i class="bi bi-table"></i>
                </a>
              </td>
            </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="9" class="text-center text-body-secondary py-4">No hay empleados activos</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
