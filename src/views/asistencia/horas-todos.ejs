<%
function fmtH(n){ if(n==null) return '-'; const h=Math.floor(n); const m=Math.round((n-h)*60); if(h===0&&m===0) return '0'; if(h===0) return m+'m'; if(m===0) return h+'h'; return h+'h '+m+'m'; }
%>
<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 gap-2">
  <div>
    <h4 class="mb-1">Consultar Horas</h4>
    <p class="text-body-secondary mb-0">Horas trabajadas por empleado (checadas en vivo). Clic en un empleado para el desglose diario.</p>
  </div>
  <a href="/checador" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-file-earmark-spreadsheet me-1"></i>Importar XLSX (respaldo)
  </a>
</div>

<!-- Filtro con flatpickr (rango) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<form method="GET" class="card mb-4" id="formFiltro">
  <div class="card-body d-flex flex-wrap gap-3 align-items-end">
    <div style="min-width:260px">
      <label class="form-label small mb-1">Rango de fechas</label>
      <input type="text" id="rango" class="form-control form-control-sm" placeholder="Selecciona rango...">
      <input type="hidden" name="fechaInicio" id="fechaInicio" value="<%= fechaInicio %>">
      <input type="hidden" name="fechaFin" id="fechaFin" value="<%= fechaFin %>">
    </div>
    <div class="d-flex align-items-center gap-2">
      <div class="form-check form-switch mb-0">
        <input class="form-check-input" type="checkbox" id="chkRedondear" name="redondear" value="1"
               <%= (typeof redondear !== 'undefined' && redondear) ? 'checked' : '' %>>
        <label class="form-check-label small" for="chkRedondear">Redondear horas</label>
      </div>
    </div>
    <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-funnel me-1"></i>Filtrar</button>
    <a id="btnExcel" href="/asistencia/horas/excel?fechaInicio=<%= fechaInicio %>&fechaFin=<%= fechaFin %>"
       class="btn btn-sm btn-success">
      <i class="bi bi-file-earmark-excel me-1"></i>Descargar Excel
    </a>
    <span class="text-body-secondary small ms-auto align-self-center">
      Periodo: <%= new Date(datos.periodo.fechaInicio).toLocaleDateString('es-MX') %> – <%= new Date(datos.periodo.fechaFin).toLocaleDateString('es-MX') %>
    </span>
  </div>
</form>

<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/es.js"></script>
<script>
  const fpInicio = document.getElementById('fechaInicio');
  const fpFin = document.getElementById('fechaFin');
  const fp = flatpickr('#rango', {
    mode: 'range',
    locale: 'es',
    dateFormat: 'Y-m-d',
    defaultDate: [fpInicio.value, fpFin.value],
    onChange: function(dates) {
      if (dates.length === 2) {
        const f = d => d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
        fpInicio.value = f(dates[0]);
        fpFin.value = f(dates[1]);
      }
    }
  });
</script>

<!-- Resumen por planta -->
<% if (datos.plantas && datos.plantas.length > 0) { %>
<div class="row g-3 mb-4">
  <% datos.plantas.forEach(function(p) { %>
  <div class="col-6 col-md-3">
    <div class="card border-primary">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <div class="text-body-secondary small"><i class="bi bi-building me-1"></i><%= p.nombre %></div>
            <div class="fs-4 fw-bold"><%= fmtH(p.horas) %></div>
          </div>
          <span class="badge bg-light text-dark border align-self-center"><%= p.dias %> días</span>
        </div>
      </div>
    </div>
  </div>
  <% }); %>
</div>
<% } %>

<!-- Panel de revisiones (días <2h con checada: probable olvido de entrada/salida) -->
<% if (datos.totalRevisiones && datos.totalRevisiones > 0) { %>
<div class="card border-warning mb-4" id="panelRevisiones">
  <div class="card-header bg-warning bg-opacity-25 d-flex justify-content-between align-items-center">
    <span class="fw-semibold">
      <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>
      <%= datos.totalRevisiones %> día(s) requieren revisión de RH
      <small class="text-body-secondary ms-1">(menos de <%= datos.umbralRevision %>h con checada — posible olvido de entrada/salida)</small>
    </span>
    <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#listaRevisiones">
      Ver / ocultar
    </button>
  </div>
  <div class="collapse show" id="listaRevisiones">
    <div class="list-group list-group-flush">
      <% datos.revisiones.forEach(function(r){ %>
        <div class="list-group-item d-flex justify-content-between align-items-start flex-wrap gap-2" data-rev-emp="<%= r.ID_Empleado %>">
          <div>
            <% if (hasRole('ADMIN','Administrador','RH','Recursos Humanos','RECURSOS_HUMANOS','SuperAdministrador')) { %>
            <a href="/asistencia/horas/<%= r.ID_Empleado %>?fechaInicio=<%= fechaInicio %>&fechaFin=<%= fechaFin %>" class="fw-semibold text-decoration-none">
              <%= r.nombre %>
            </a>
            <% } else { %><span class="fw-semibold"><%= r.nombre %></span><% } %>
            <% if (r.area) { %><small class="text-body-secondary ms-1"><%= r.area %></small><% } %>
            <div class="mt-1 d-flex flex-wrap gap-1">
              <% r.dias.forEach(function(d){ %>
                <span class="badge bg-warning text-dark" title="<%= d.motivo %> · entrada <%= d.entrada||'—' %> / salida <%= d.salida||'—' %>">
                  <%= d.nombreDia %> <%= new Date(d.fecha + 'T12:00:00').toLocaleDateString('es-MX', {day:'2-digit', month:'2-digit'}) %>:
                  <%= d.horas.toFixed(1) %>h · <%= d.motivo %>
                </span>
              <% }); %>
            </div>
          </div>
          <div class="d-flex gap-2 align-self-center">
            <% if (hasRole('ADMIN','Administrador','RH','Recursos Humanos','RECURSOS_HUMANOS','SuperAdministrador')) { %>
            <a href="/asistencia/horas/<%= r.ID_Empleado %>?fechaInicio=<%= fechaInicio %>&fechaFin=<%= fechaFin %>" class="btn btn-sm btn-outline-primary">
              <i class="bi bi-eye me-1"></i>Revisar
            </a>
            <% } %>
            <button type="button" class="btn btn-sm btn-outline-secondary btn-descartar-rev" data-rev-emp="<%= r.ID_Empleado %>">
              <i class="bi bi-check2 me-1"></i>Descartar
            </button>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
</div>
<% } %>

<!-- Matriz tipo checador (empleados × días) -->
<%
const DIAS = ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
function fmtFechaCorta(d){ const x=new Date(d); return String(x.getDate()).padStart(2,'0')+'/'+String(x.getMonth()+1).padStart(2,'0'); }
%>
<style>
  .matriz-horas th, .matriz-horas td { font-size:.78rem; white-space:nowrap; }
  .matriz-horas .th-dom { background:#f1f3f5; }
  .matriz-horas .th-sab { background:#fff3cd; }
  .matriz-horas td.cel-completa { background:#d1e7dd; }
  .matriz-horas td.cel-parcial  { background:#fff3cd; }
  .matriz-horas td.cel-ausente  { background:#f8d7da; }
  .matriz-horas td.cel-dom      { background:#f1f3f5; }
  .matriz-horas td.cel-revision { background:#ffe0b2; outline:2px solid #fd7e14; outline-offset:-2px; }
  .matriz-horas td.cel-revision .hrs { color:#d63384; }
  .matriz-horas .col-id  { position:sticky; left:0; background:#fff; z-index:2; min-width:48px; }
  .matriz-horas .col-emp { position:sticky; left:48px; background:#fff; z-index:2; min-width:190px; }
  .matriz-horas thead .col-id, .matriz-horas thead .col-emp { z-index:3; }
  .matriz-horas .cel-es { line-height:1.15; }
  .matriz-horas .cel-es .ent { color:#0d6efd; }
  .matriz-horas .cel-es .sal { color:#dc3545; }
  .matriz-horas .cel-es .hrs { font-weight:600; border-top:1px solid #ccc; }
  .matriz-horas th.sortable { cursor:pointer; user-select:none; }
  .matriz-horas th.sortable:hover { background:#e9ecef; }
  .matriz-horas th .arrow { font-size:.65rem; opacity:.5; }
</style>

<!-- Buscador -->
<div class="mb-3" style="max-width:340px">
  <div class="input-group input-group-sm">
    <span class="input-group-text"><i class="bi bi-search"></i></span>
    <input type="text" id="buscarEmp" class="form-control" placeholder="Buscar por nombre o ID...">
  </div>
</div>

<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-bordered table-sm mb-0 matriz-horas align-middle" id="tablaMatriz">
        <thead class="table-light">
          <tr>
            <th class="col-id text-center sortable" data-sort="id" data-type="num">ID <span class="arrow"></span></th>
            <th class="col-emp sortable" data-sort="nombre" data-type="str">Empleado <span class="arrow"></span></th>
            <% datos.fechas.forEach(function(f){ const dw=new Date(f).getDay(); %>
              <th class="text-center <%= dw===0?'th-dom':'' %> <%= dw===6?'th-sab':'' %>">
                <div class="small text-body-secondary"><%= DIAS[dw] %></div>
                <div><%= fmtFechaCorta(f) %></div>
              </th>
            <% }); %>
            <th class="text-center">Norm</th>
            <th class="text-center">Extra</th>
            <th class="text-center sortable" data-sort="total" data-type="num">Total <span class="arrow"></span></th>
            <th class="text-center">Ret</th>
          </tr>
        </thead>
        <tbody id="matrizBody">
          <% if (datos.filas && datos.filas.length > 0) { %>
            <% datos.filas.forEach(function(f) { %>
            <tr data-id="<%= f.ID_Empleado %>" data-nombre="<%= f.nombre.toLowerCase() %>" data-total="<%= f.horas %>">
              <td class="col-id text-center text-body-secondary"><%= f.ID_Empleado %></td>
              <td class="col-emp">
                <% if (hasRole('ADMIN','Administrador','RH','Recursos Humanos','RECURSOS_HUMANOS','SuperAdministrador')) { %>
                <a href="/asistencia/horas/<%= f.ID_Empleado %>?fechaInicio=<%= fechaInicio %>&fechaFin=<%= fechaFin %>" class="text-decoration-none fw-semibold">
                  <%= f.nombre %>
                </a>
                <% } else { %><span class="fw-semibold"><%= f.nombre %></span><% } %>
                <% if (f.multi > 0) { %><span class="badge bg-info ms-1" style="font-size:.6rem" title="<%= f.multi %> día(s) multi-planta">MP</span><% } %>
              </td>
              <% f.celdas.forEach(function(c){
                   let cls='', tip='';
                   if (c.esDomingo) { cls='cel-dom'; }
                   else if (!c.presente && c.vacio) { cls='cel-ausente'; tip='Ausente'; }
                   else if (c.requiereRevision) { cls='cel-revision'; tip='Requiere revisión RH · ' + (c.horas||0).toFixed(1) + 'h (menos de 2h con checada)'; }
                   else if (c.enCurso) { cls='cel-parcial'; tip='En curso (sin salida)'; }
                   else if (c.incompleta) { cls='cel-parcial'; tip='Incompleta · estimada a 18:00'; }
                   else if (c.presente) { cls = c.jornadaCompleta ? 'cel-completa' : ''; tip=(c.planta||''); }
              %>
                <td class="text-center <%= cls %> cel-dia"
                    title="<%= tip %>"
                    data-ent="<%= c.entrada || '' %>"
                    data-sal="<%= c.salida || '' %>"
                    data-horas="<%= c.horas || 0 %>"
                    data-presente="<%= c.presente ? 1 : 0 %>"
                    data-dom="<%= c.esDomingo ? 1 : 0 %>"
                    data-vacio="<%= (!c.presente && c.vacio) ? 1 : 0 %>">
                  <% if (c.esDomingo) { %>
                    <span class="text-body-secondary small">Dom</span>
                  <% } else if (!c.presente && c.vacio) { %>
                    <span class="text-danger fw-bold">Falta</span>
                  <% } else if (c.presente) { %>
                    <div class="cel-es">
                      <div class="ent"><%= c.entrada || '--:--' %></div>
                      <div class="sal"><%= c.salida || '--:--' %></div>
                      <% if (c.requiereRevision) { %>
                        <div class="hrs"><i class="bi bi-exclamation-triangle-fill text-warning"></i> <%= (c.horas||0).toFixed(1) %>h</div>
                      <% } else if (c.enCurso) { %>
                        <div class="hrs text-primary"><i class="bi bi-hourglass-split"></i> <%= (c.horas||0).toFixed(1) %>h</div>
                      <% } else { %>
                        <div class="hrs"><%= (c.horas||0).toFixed(1) %>h</div>
                      <% } %>
                    </div>
                  <% } else { %>-<% } %>
                </td>
              <% }); %>
              <td class="text-center col-normal"><%= f.normales>0?f.normales.toFixed(1):'-' %></td>
              <td class="text-center col-extra"><%= f.extras>0?f.extras.toFixed(1):'-' %></td>
              <td class="text-center fw-bold col-total"><%= f.horas>0?f.horas.toFixed(1):'0' %></td>
              <td class="text-center <%= f.retardos>0?'text-danger fw-bold':'' %>"><%= f.retardos>0?f.retardos:'-' %></td>
            </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="<%= datos.fechas.length + 6 %>" class="text-center text-body-secondary py-4">No hay empleados activos</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
(function(){
  const tbody = document.getElementById('matrizBody');
  const inputBuscar = document.getElementById('buscarEmp');
  const getRows = () => Array.from(tbody.querySelectorAll('tr[data-id]'));

  // --- Buscar por nombre o ID ---
  inputBuscar.addEventListener('input', function(){
    const q = this.value.toLowerCase().trim();
    getRows().forEach(tr => {
      const match = tr.dataset.nombre.includes(q) || tr.dataset.id.includes(q);
      tr.style.display = match ? '' : 'none';
    });
  });

  // --- Ordenar por columna ---
  let sortState = { key: null, asc: true };
  document.querySelectorAll('#tablaMatriz th.sortable').forEach(th => {
    th.addEventListener('click', function(){
      const key = this.dataset.sort;
      const type = this.dataset.type;
      sortState.asc = (sortState.key === key) ? !sortState.asc : true;
      sortState.key = key;

      const rows = getRows();
      rows.sort((a, b) => {
        let va = a.dataset[key], vb = b.dataset[key];
        if (type === 'num') { va = parseFloat(va)||0; vb = parseFloat(vb)||0; return sortState.asc ? va-vb : vb-va; }
        return sortState.asc ? va.localeCompare(vb) : vb.localeCompare(va);
      });
      rows.forEach(r => tbody.appendChild(r));

      // Flechas indicadoras
      document.querySelectorAll('#tablaMatriz th.sortable .arrow').forEach(a => a.textContent = '');
      this.querySelector('.arrow').textContent = sortState.asc ? '▲' : '▼';

      actualizarLinkExcel();
    });
  });

  // ---- Redondeo de horas ----
  function redondearEntrada(hhmm) {
    if (!hhmm) return hhmm;
    const [h, m] = hhmm.split(':').map(Number);
    if (m <= 15) return String(h).padStart(2,'0') + ':00';
    return String(h + 1).padStart(2,'0') + ':00';
  }
  function redondearSalida(hhmm) {
    if (!hhmm) return hhmm;
    const [h, m] = hhmm.split(':').map(Number);
    // Baja a la hora si faltan 5+ min para la siguiente (m<=55); sube solo en
    // los últimos 4 min (m>=56). Ej: 8:54->8:00, 8:56->9:00, 18:30->18:00.
    if (m <= 55) return String(h).padStart(2,'0') + ':00';
    return String(h + 1).padStart(2,'0') + ':00';
  }
  function minutosEntre(ent, sal) {
    const [he, me] = ent.split(':').map(Number);
    const [hs, ms] = sal.split(':').map(Number);
    const COMIDA_INI = 14*60, COMIDA_FIN = 15*60;
    const CIERRE = 18*60;
    const entMin = he*60+me, salMin = hs*60+ms;
    if (salMin <= entMin) return 0;
    let netos = salMin - entMin;
    // descuento comida si jornada cruza 14-15
    if (entMin < COMIDA_FIN && salMin > COMIDA_INI) {
      netos -= Math.min(salMin, COMIDA_FIN) - Math.max(entMin, COMIDA_INI);
    }
    return Math.max(0, netos);
  }

  const chk = document.getElementById('chkRedondear');
  const LIMITE_SEMANAL = 45; // tope de horas normales; excedente = extra
  function aplicarRedondeo() {
    const activo = chk.checked;
    // Recalcular celda por celda y totalizar por fila para reflejar el redondeo
    // en Total / Normal / Extra (split semanal de 45h).
    getRows().forEach(tr => {
      let totalFila = 0;
      tr.querySelectorAll('.cel-dia').forEach(td => {
        if (td.dataset.dom === '1' || td.dataset.vacio === '1' || td.dataset.presente !== '1') return;
        const entRaw = td.dataset.ent;
        const salRaw = td.dataset.sal;
        const horasRaw = parseFloat(td.dataset.horas) || 0;
        const celEs = td.querySelector('.cel-es');
        if (!celEs) return;

        let entMostrar, salMostrar, horasMostrar;
        if (activo && entRaw && salRaw) {
          entMostrar = redondearEntrada(entRaw);
          salMostrar = redondearSalida(salRaw);
          const mins = minutosEntre(entMostrar, salMostrar);
          horasMostrar = Math.round((mins / 60) * 10) / 10;
        } else {
          entMostrar = entRaw || '--:--';
          salMostrar = salRaw || '--:--';
          horasMostrar = Math.round(horasRaw * 10) / 10;
        }
        celEs.querySelector('.ent').textContent = entMostrar;
        celEs.querySelector('.sal').textContent = salMostrar;
        celEs.querySelector('.hrs').textContent = horasMostrar.toFixed(1) + 'h';
        totalFila += horasMostrar;
      });

      totalFila = Math.round(totalFila * 100) / 100;
      const extra = Math.max(0, Math.round((totalFila - LIMITE_SEMANAL) * 100) / 100);
      const normal = Math.round((totalFila - extra) * 100) / 100;
      const tdNorm = tr.querySelector('.col-normal');
      const tdExtra = tr.querySelector('.col-extra');
      const tdTotal = tr.querySelector('.col-total');
      if (tdNorm) tdNorm.textContent = normal > 0 ? normal.toFixed(1) : '-';
      if (tdExtra) tdExtra.textContent = extra > 0 ? extra.toFixed(1) : '-';
      if (tdTotal) tdTotal.textContent = totalFila > 0 ? totalFila.toFixed(1) : '0';
      tr.dataset.total = totalFila; // mantener orden por total coherente
    });
  }
  chk.addEventListener('change', aplicarRedondeo);
  // Aplicar estado inicial si viene con ?redondear=1
  if (chk.checked) aplicarRedondeo();

  // El botón Excel actualiza su href con fechas + orden + redondeo vivos
  const btnExcel = document.getElementById('btnExcel');
  function actualizarLinkExcel(){
    if (!btnExcel) return;
    const fi = document.getElementById('fechaInicio').value;
    const ff = document.getElementById('fechaFin').value;
    let url = `/asistencia/horas/excel?fechaInicio=${fi}&fechaFin=${ff}`;
    if (sortState.key) url += `&sort=${sortState.key}&dir=${sortState.asc ? 'asc' : 'desc'}`;
    if (document.getElementById('chkRedondear').checked) url += '&redondear=1';
    btnExcel.href = url;
  }
  if (btnExcel) btnExcel.addEventListener('click', actualizarLinkExcel);
  chk.addEventListener('change', actualizarLinkExcel);

  // --- Revisiones <2h: descartar (solo UI/sesión) + confirmar antes de descargar ---
  const panel = document.getElementById('panelRevisiones');
  function pendientesRevision(){
    if (!panel) return [];
    return Array.from(panel.querySelectorAll('.list-group-item:not([data-descartada])'));
  }
  // Descartar una persona de la lista (no persiste; solo oculta para esta sesión)
  document.querySelectorAll('.btn-descartar-rev').forEach(btn => {
    btn.addEventListener('click', function(){
      const item = this.closest('.list-group-item');
      item.setAttribute('data-descartada', '1');
      item.style.opacity = '.45';
      item.querySelectorAll('a, button').forEach(el => { el.classList.add('disabled'); el.setAttribute('tabindex','-1'); });
      this.innerHTML = '<i class="bi bi-check2-all me-1"></i>Revisado';
      // Si ya no quedan pendientes, atenuar el header del panel
      if (pendientesRevision().length === 0) {
        panel.querySelector('.card-header').classList.add('bg-opacity-10');
      }
    });
  });
  // Confirmar antes de descargar Excel si hay días sin revisar
  if (btnExcel) {
    btnExcel.addEventListener('click', function(ev){
      const pend = pendientesRevision();
      if (pend.length === 0) return; // nada que revisar
      const nombres = pend.map(i => i.querySelector('.fw-semibold')?.textContent.trim()).filter(Boolean);
      const lista = nombres.slice(0, 8).join(', ') + (nombres.length > 8 ? `, +${nombres.length - 8} más` : '');
      const ok = window.confirm(
        `Hay ${pend.length} persona(s) con días de menos de 2h (posible olvido de checada):\n\n${lista}\n\n` +
        `Revisa o descarta antes de exportar. ¿Descargar el Excel de todas formas?`
      );
      if (!ok) ev.preventDefault();
    });
  }
})();
</script>

