<!-- Header -->
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 gap-2">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item"><a href="/asistencia">Asistencia</a></li>
                        <li class="breadcrumb-item active">Desglose del Día</li>
                    </ol>
                </nav>
                <h1 class="h3 mb-0">Desglose del Día</h1>
                <p class="text-body-secondary mb-0">
                    <%= new Date(fecha + 'T12:00:00').toLocaleDateString('es-MX', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
                </p>
            </div>
            <a href="/asistencia" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-2"></i>Volver
            </a>
        </div>

        <!-- Filtros -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <form method="GET" action="/asistencia/dia" class="row g-3 align-items-end">
                    <div class="col-6 col-md-4">
                        <label for="fecha" class="form-label">Fecha</label>
                        <input type="date" class="form-control" id="fecha" name="fecha" value="<%= fecha %>">
                    </div>
                    <div class="col-6 col-md-4">
                        <label for="planta" class="form-label">Planta (tabla)</label>
                        <select class="form-select" id="planta" name="planta">
                            <option value="" <%= plantaSeleccionada == null ? 'selected' : '' %>>Todas</option>
                            <% plantas.forEach(pl => { %>
                                <option value="<%= pl.ID_Planta %>" <%= plantaSeleccionada === pl.ID_Planta ? 'selected' : '' %>>
                                    <%= pl.Nombre %>
                                </option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-search me-2"></i>Ver
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Presencia EN VIVO por planta -->
        <div class="d-flex align-items-center mb-3">
            <h5 class="mb-0"><i class="bi bi-broadcast me-2 text-success"></i>Quién está dentro ahora</h5>
            <span class="badge bg-success ms-2"><%= presencia.totalPresentes %> presentes</span>
            <small class="text-body-secondary ms-2">(entrada sin salida)</small>
        </div>

        <% if (!presencia.plantas || presencia.plantas.length === 0 || presencia.totalPresentes === 0) { %>
            <div class="alert alert-secondary border-0 shadow-sm">
                <i class="bi bi-person-x me-2"></i>Nadie con entrada activa en esta fecha.
            </div>
        <% } else { %>
        <!-- Desglose por planta > áreas (acordeón) -->
        <div class="accordion shadow-sm mb-4" id="accPlantas">
            <% presencia.plantas.forEach((pl, i) => { %>
                <% const accent = pl.id < 0 ? 'warning' : (i % 2 === 0 ? 'info' : 'secondary'); %>
                <% const pid = 'pl' + (pl.id < 0 ? 'X' : pl.id); %>
                <div class="accordion-item border-0 mb-2">
                    <h2 class="accordion-header">
                        <button class="accordion-button <%= i === 0 ? '' : 'collapsed' %> bg-<%= accent %> bg-opacity-10 fw-semibold"
                                type="button" data-bs-toggle="collapse" data-bs-target="#c<%= pid %>"
                                aria-expanded="<%= i === 0 ? 'true' : 'false' %>" aria-controls="c<%= pid %>">
                            <i class="bi bi-geo-alt-fill me-2 text-<%= accent %>"></i>
                            <span class="me-2"><%= pl.nombre %></span>
                            <span class="badge bg-<%= accent %>"><%= pl.total %> dentro</span>
                            <small class="text-body-secondary ms-2"><%= pl.areas.length %> área(s)</small>
                        </button>
                    </h2>
                    <div id="c<%= pid %>" class="accordion-collapse collapse <%= i === 0 ? 'show' : '' %>" data-bs-parent="#accPlantas">
                        <div class="accordion-body p-2">
                            <% pl.areas.forEach(ar => { %>
                                <div class="mb-2">
                                    <div class="d-flex justify-content-between align-items-center px-2 py-1 bg-body-secondary rounded-top">
                                        <span class="fw-semibold"><i class="bi bi-diagram-3 me-1"></i><%= ar.nombre %></span>
                                        <span class="badge bg-secondary"><%= ar.total %></span>
                                    </div>
                                    <div class="list-group list-group-flush border rounded-bottom">
                                        <% ar.empleados.forEach(p => { %>
                                            <% var puedeDetalle = hasRole('ADMIN','Administrador','RH','Recursos Humanos','RECURSOS_HUMANOS','SuperAdministrador'); %>
                                            <<%= puedeDetalle ? 'a' : 'div' %> <% if (puedeDetalle) { %>href="/asistencia/empleado/<%= p.id %>"<% } %> class="list-group-item <%= puedeDetalle ? 'list-group-item-action' : '' %> d-flex justify-content-between align-items-center py-2">
                                                <div>
                                                    <div class="fw-semibold"><%= p.nombre %></div>
                                                    <small class="text-body-secondary"><%= p.puesto || '' %></small>
                                                </div>
                                                <div class="text-end">
                                                    <span class="badge bg-success">
                                                        <i class="bi bi-box-arrow-in-right"></i>
                                                        <%= new Date(p.entrada).toLocaleTimeString('es-MX', {hour:'2-digit', minute:'2-digit'}) %>
                                                    </span>
                                                    <% if (p.retardo) { %><br><small class="text-danger">retardo</small><% } %>
                                                </div>
                                            </<%= puedeDetalle ? 'a' : 'div' %>>
                                        <% }); %>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
        <% } %>

        <!-- Tabla cronológica COMPLETA del día -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Todas las checadas del día</h5>
                    <small class="text-body-secondary">Las marcadas <span class="badge bg-warning text-dark">doble</span> caen dentro de 1h de la anterior y se ignoran al calcular horas.</small>
                </div>
                <span class="badge bg-primary"><%= dia.total %> registros</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive" style="max-height: 600px;">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>Hora</th>
                                <th>Empleado</th>
                                <th>Área</th>
                                <th>Tipo</th>
                                <th>Planta</th>
                                <th>Origen</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (dia.checadas && dia.checadas.length > 0) { %>
                                <% dia.checadas.forEach(c => { %>
                                    <tr class="<%= c.ignoradaDoble ? 'table-warning text-muted' : '' %>">
                                        <td>
                                            <strong><%= new Date(c.hora).toLocaleTimeString('es-MX', {hour:'2-digit', minute:'2-digit'}) %></strong>
                                            <% if (c.ignoradaDoble) { %>
                                                <span class="badge bg-warning text-dark ms-1" title="Doble checada dentro de 1h — ignorada en el cálculo de horas">doble</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (c.empleado) { %>
                                                <% if (hasRole('ADMIN','Administrador','RH','Recursos Humanos','RECURSOS_HUMANOS','SuperAdministrador')) { %>
                                                <a href="/asistencia/empleado/<%= c.empleado.id %>" class="text-decoration-none"><%= c.empleado.nombre %></a>
                                                <% } else { %><%= c.empleado.nombre %><% } %>
                                            <% } else { %>
                                                <span class="text-body-secondary">Desconocido</span>
                                            <% } %>
                                        </td>
                                        <td><small><%= c.empleado && c.empleado.area || '-' %></small></td>
                                        <td>
                                            <% if (c.tipo === 'ENTRADA') { %><span class="badge bg-success">Entrada</span>
                                            <% } else if (c.tipo === 'SALIDA') { %><span class="badge bg-primary">Salida</span>
                                            <% } else { %><span class="badge bg-secondary"><%= c.tipo %></span><% } %>
                                        </td>
                                        <td><span class="badge bg-info-subtle text-info-emphasis border border-info-subtle"><%= c.planta %></span></td>
                                        <td>
                                            <% if (c.origen === 'MANUAL' || c.dispositivo === 'MANUAL') { %>
                                                <span class="badge bg-warning text-dark" title="Registro manual"><i class="bi bi-hand-index-thumb"></i> Manual</span>
                                            <% } else { %><small class="text-body-secondary"><%= c.origen %></small><% } %>
                                        </td>
                                        <td>
                                            <%
                                                var esEntradaDia = c.tipo === 'ENTRADA';
                                                var estadoDia = c.estado;
                                                if (esEntradaDia && c.jornadaRetardo) estadoDia = 'RETARDO';
                                            %>
                                            <% if (estadoDia === 'A_TIEMPO') { %><span class="text-success"><i class="bi bi-check-circle-fill"></i></span>
                                            <% } else if (estadoDia === 'TOLERANCIA') { %><span class="text-warning"><i class="bi bi-exclamation-circle-fill"></i></span>
                                            <% } else if (estadoDia === 'RETARDO') { %><span class="text-danger"><i class="bi bi-x-circle-fill"></i> Retardo</span>
                                            <% } else { %><small class="text-body-secondary"><%= estadoDia %></small><% } %>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="7" class="text-center py-4 text-body-secondary">
                                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                        Sin checadas registradas en esta fecha
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
