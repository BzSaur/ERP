<!-- Header -->
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 gap-2">
            <div>
                <h1 class="h3 mb-1">Control de Asistencia</h1>
                <p class="text-body-secondary mb-0">
                    Resumen del día: <%= new Date().toLocaleDateString('es-MX', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
                </p>
            </div>
            <div>
                <% if (hasRole('ADMIN','Administrador','RH','Recursos Humanos','RECURSOS_HUMANOS','SuperAdministrador')) { %>
                <a href="/asistencia/checada-manual" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-2"></i>Checada Manual
                </a>
                <% } %>
            </div>
        </div>

        <!-- Tarjetas de resumen -->
        <div class="row mb-4">
            <div class="col-md-3 col-sm-6 mb-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-body-secondary mb-1 small text-uppercase">Presentes</p>
                                <h2 class="mb-0 text-success"><%= resumen.totalPresentes %></h2>
                            </div>
                            <div class="bg-success bg-opacity-10 p-3 rounded">
                                <i class="bi bi-person-check text-success fs-4"></i>
                            </div>
                        </div>
                        <% if (hasRole('ADMIN','Administrador','RH','Recursos Humanos','RECURSOS_HUMANOS','SuperAdministrador')) { %>
                        <div class="mt-2">
                            <small class="text-body-secondary">
                                <%= resumen.porcentajeAsistencia %>% de asistencia
                            </small>
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <% if (hasRole('ADMIN','Administrador','RH','Recursos Humanos','RECURSOS_HUMANOS','SuperAdministrador')) { %>
            <div class="col-md-3 col-sm-6 mb-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-body-secondary mb-1 small text-uppercase">Ausentes</p>
                                <h2 class="mb-0 text-danger"><%= resumen.totalAusentes %></h2>
                            </div>
                            <div class="bg-danger bg-opacity-10 p-3 rounded">
                                <i class="bi bi-person-x text-danger fs-4"></i>
                            </div>
                        </div>
                        <div class="mt-2">
                            <small class="text-body-secondary">
                                De <%= resumen.totalEmpleadosActivos %> empleados activos
                            </small>
                        </div>
                    </div>
                </div>
            </div>
            <% } %>

            <div class="col-md-3 col-sm-6 mb-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-body-secondary mb-1 small text-uppercase">Retardos</p>
                                <h2 class="mb-0 text-warning"><%= resumen.conRetardo %></h2>
                            </div>
                            <div class="bg-warning bg-opacity-10 p-3 rounded">
                                <i class="bi bi-clock-history text-warning fs-4"></i>
                            </div>
                        </div>
                        <div class="mt-2">
                            <small class="text-body-secondary">
                                Después de tolerancia
                            </small>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-md-3 col-sm-6 mb-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-body-secondary mb-1 small text-uppercase">Por Ubicación</p>
                                <h5 class="mb-0 d-flex flex-wrap gap-1">
                                    <% if (resumen.porUbicacion && resumen.porUbicacion.length > 0) { %>
                                        <% resumen.porUbicacion.forEach((u, i) => { %>
                                            <span class="badge bg-<%= i % 2 === 0 ? 'info' : 'secondary' %>"><%= u.nombre %>: <%= u.total %></span>
                                        <% }); %>
                                    <% } else { %>
                                        <span class="badge bg-light text-dark">Sin datos</span>
                                    <% } %>
                                </h5>
                            </div>
                            <div class="bg-info bg-opacity-10 p-3 rounded">
                                <i class="bi bi-geo-alt text-info fs-4"></i>
                            </div>
                        </div>
                        <div class="mt-2">
                            <a href="/asistencia/por-ubicacion" class="text-decoration-none small">
                                Ver detalle <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Últimas checadas -->
            <div class="col-lg-8 mb-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0">
                            <i class="bi bi-clock me-2"></i>Últimas Checadas
                        </h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Hora</th>
                                        <th>Empleado</th>
                                        <th>Tipo</th>
                                        <th>Ubicación</th>
                                        <th>Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (ultimasChecadas && ultimasChecadas.length > 0) { %>
                                        <% ultimasChecadas.forEach(checada => { %>
                                            <tr>
                                                <td>
                                                    <strong>
                                                        <%= new Date(checada.Fecha_Hora).toLocaleTimeString('es-MX', { hour: '2-digit', minute: '2-digit' }) %>
                                                    </strong>
                                                    <br>
                                                    <small class="text-body-secondary">
                                                        <%= new Date(checada.Fecha_Hora).toLocaleDateString('es-MX') %>
                                                    </small>
                                                </td>
                                                <td>
                                                    <% if (hasRole('ADMIN','Administrador','RH','Recursos Humanos','RECURSOS_HUMANOS','SuperAdministrador')) { %>
                                                    <a href="/asistencia/empleado/<%= checada.asistencia.empleado.ID_Empleado %>"
                                                       class="text-decoration-none">
                                                        <%= checada.asistencia.empleado.Nombre %>
                                                        <%= checada.asistencia.empleado.Apellido_Paterno %>
                                                    </a>
                                                    <% } else { %>
                                                        <%= checada.asistencia.empleado.Nombre %> <%= checada.asistencia.empleado.Apellido_Paterno %>
                                                    <% } %>
                                                    <br>
                                                    <small class="text-body-secondary">
                                                        #<%= checada.asistencia.empleado.ID_Empleado %>
                                                    </small>
                                                </td>
                                                <td>
                                                    <% if (checada.Tipo_Checada === 'ENTRADA') { %>
                                                        <span class="badge bg-success">Entrada</span>
                                                    <% } else { %>
                                                        <span class="badge bg-primary">Salida</span>
                                                    <% } %>
                                                    <% if (checada.Origen_Sincronizacion === 'MANUAL' || checada.Dispositivo === 'MANUAL') { %>
                                                        <span class="badge bg-warning text-dark" title="Registro manual"><i class="bi bi-hand-index-thumb"></i> Manual</span>
                                                    <% } %>
                                                </td>
                                                <td>
                                                    <span class="badge bg-<%= checada.Ubicacion === 'RAM1' ? 'info' : 'secondary' %>">
                                                        <%= checada.Ubicacion %>
                                                    </span>
                                                </td>
                                                <td>
                                                    <%
                                                        var esEntrada = checada.Tipo_Checada === 'ENTRADA';
                                                        var jornadaRetardo = checada.asistencia && checada.asistencia.Retardo;
                                                        var estadoMostrar = checada.Estado;
                                                        if (esEntrada && jornadaRetardo) estadoMostrar = 'RETARDO';
                                                    %>
                                                    <% if (estadoMostrar === 'A_TIEMPO') { %>
                                                        <span class="text-success">
                                                            <i class="bi bi-check-circle-fill"></i> A tiempo
                                                        </span>
                                                    <% } else if (estadoMostrar === 'TOLERANCIA') { %>
                                                        <span class="text-warning">
                                                            <i class="bi bi-exclamation-circle-fill"></i> Tolerancia
                                                        </span>
                                                    <% } else if (estadoMostrar === 'RETARDO') { %>
                                                        <span class="text-danger">
                                                            <i class="bi bi-x-circle-fill"></i> Retardo
                                                        </span>
                                                    <% } else { %>
                                                        <span class="text-body-secondary">
                                                            <i class="bi bi-dash-circle"></i> <%= estadoMostrar %>
                                                        </span>
                                                    <% } %>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="5" class="text-center py-4 text-body-secondary">
                                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                                No hay checadas registradas hoy
                                            </td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Panel lateral -->
            <div class="col-lg-4">
                <!-- Accesos rápidos -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0">
                            <i class="bi bi-lightning me-2"></i>Acciones Rápidas
                        </h5>
                    </div>
                    <div class="list-group list-group-flush">
                        <% if (hasRole('ADMIN','Administrador','RH','Recursos Humanos','RECURSOS_HUMANOS','SuperAdministrador')) { %>
                        <a href="/asistencia/checada-manual" class="list-group-item list-group-item-action">
                            <i class="bi bi-plus-circle me-2"></i>Registrar Checada Manual
                        </a>
                        <% } %>
                        <a href="/asistencia/por-ubicacion" class="list-group-item list-group-item-action">
                            <i class="bi bi-geo-alt me-2"></i>Reporte por Ubicación
                        </a>
                        <a href="/asistencia/dia" class="list-group-item list-group-item-action">
                            <i class="bi bi-calendar-day me-2"></i>Desglose del Día
                        </a>
                        <% if (hasRole('ADMIN','Administrador','RH','Recursos Humanos','RECURSOS_HUMANOS','SuperAdministrador')) { %>
                        <a href="/reportes" class="list-group-item list-group-item-action">
                            <i class="bi bi-file-earmark-bar-graph me-2"></i>Reportes Generales
                        </a>
                        <% } %>
                    </div>
                </div>

                <!-- Detalle del día -->
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0">
                            <i class="bi bi-list-check me-2"></i>Detalle del Día
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Con entrada registrada:</span>
                            <strong><%= resumen.conEntrada %></strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Con salida registrada:</span>
                            <strong><%= resumen.conSalida %></strong>
                        </div>
                        <% if (hasRole('ADMIN','Administrador','RH','Recursos Humanos','RECURSOS_HUMANOS','SuperAdministrador')) { %>
                        <hr>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Empleados activos:</span>
                            <strong><%= resumen.totalEmpleadosActivos %></strong>
                        </div>
                        <div class="progress mt-3" style="height: 25px;">
                            <div class="progress-bar bg-success"
                                 role="progressbar"
                                 style="width: <%= resumen.porcentajeAsistencia %>%"
                                 aria-valuenow="<%= resumen.porcentajeAsistencia %>"
                                 aria-valuemin="0"
                                 aria-valuemax="100">
                                <%= resumen.porcentajeAsistencia %>% Asistencia
                            </div>
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
