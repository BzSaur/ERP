<div class="mb-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb mb-1">
      <li class="breadcrumb-item"><a href="/checadores">Checadores</a></li>
      <li class="breadcrumb-item active">Diagnóstico</li>
    </ol>
  </nav>
  <h4 class="mb-0">Diagnóstico: <%= checador.Nombre %></h4>
  <p class="text-body-secondary mb-0"><code><%= checador.Serial_Number %></code> · <%= checador.planta ? checador.planta.Nombre : '-' %></p>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="card"><div class="card-body">
      <div class="text-body-secondary small">Última conexión</div>
      <div class="fw-semibold"><%= checador.Ultima_Conexion ? new Date(checador.Ultima_Conexion).toLocaleString('es-MX') : 'Nunca' %></div>
      <div class="small text-body-secondary">IP: <%= checador.Ultima_IP_Origen || '-' %></div>
    </div></div>
  </div>
  <div class="col-md-3">
    <div class="card"><div class="card-body">
      <div class="text-body-secondary small">Última checada</div>
      <div class="fw-semibold">
        <%= ultimaChecada ? new Date(ultimaChecada.Fecha_Hora).toLocaleString('es-MX') : 'Sin registros' %>
      </div>
      <% if (ultimaChecada && ultimaChecada.asistencia) { %>
        <div class="small text-body-secondary">Empleado #<%= ultimaChecada.asistencia.ID_Empleado %></div>
      <% } %>
    </div></div>
  </div>
  <div class="col-md-2">
    <div class="card"><div class="card-body">
      <div class="text-body-secondary small">Comandos pend.</div>
      <div class="fs-4 fw-bold"><%= comandosPendientes %></div>
    </div></div>
  </div>
  <div class="col-md-2">
    <div class="card"><div class="card-body">
      <div class="text-body-secondary small">Requests 24h</div>
      <div class="fs-4 fw-bold"><%= logs24h %></div>
    </div></div>
  </div>
  <div class="col-md-2">
    <div class="card"><div class="card-body">
      <div class="text-body-secondary small">Latencia prom.</div>
      <div class="fs-4 fw-bold"><%= latenciaPromedio !== null ? latenciaPromedio + ' ms' : '-' %></div>
    </div></div>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <h6>Estado del reloj</h6>
    <p class="mb-1">Offset detectado: <strong><%= checador.Offset_Tiempo_Min %> min</strong></p>
    <% if (Math.abs(checador.Offset_Tiempo_Min) > 5) { %>
      <div class="alert alert-warning mb-0"><i class="bi bi-clock-history me-2"></i>El reloj del device está desfasado. Se encoló un comando SET_TIME (si no había uno pendiente).</div>
    <% } else { %>
      <div class="text-success"><i class="bi bi-check-circle me-1"></i>Reloj sincronizado.</div>
    <% } %>
  </div>
</div>

<div class="card mt-3">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center">
      <h6 class="mb-0">Logs del checador (ADMS)</h6>
      <button type="button" id="btnLogs" class="btn btn-sm btn-outline-info" onclick="toggleLogs(<%= checador.ID_Checador %>)">
        <i class="bi bi-list-ul me-1"></i><span id="btnLogsTxt">Ver logs</span>
      </button>
    </div>
    <div id="logsBox" class="mt-3" style="display:none">
      <div class="table-responsive" style="max-height:360px; overflow-y:auto">
        <table class="table table-sm table-hover mb-0">
          <thead class="table-light" style="position:sticky; top:0">
            <tr><th>Fecha</th><th>Endpoint</th><th class="text-center">Código</th><th class="text-end">ms</th><th>Error</th></tr>
          </thead>
          <tbody id="logsBody">
            <tr><td colspan="5" class="text-center text-body-secondary py-3">Cargando…</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
let logsCargados = false;
async function toggleLogs(id) {
  const box = document.getElementById('logsBox');
  const txt = document.getElementById('btnLogsTxt');
  if (box.style.display === 'none') {
    box.style.display = 'block';
    txt.textContent = 'Ocultar logs';
    if (!logsCargados) await cargarLogs(id);
  } else {
    box.style.display = 'none';
    txt.textContent = 'Ver logs';
  }
}
async function cargarLogs(id) {
  const body = document.getElementById('logsBody');
  try {
    const r = await fetch(`/checadores/${id}/logs?limit=100`);
    const data = await r.json();
    if (!data.logs || data.logs.length === 0) {
      body.innerHTML = '<tr><td colspan="5" class="text-center text-body-secondary py-3">Sin logs registrados</td></tr>';
      return;
    }
    body.innerHTML = data.logs.map(l => {
      const fecha = new Date(l.fecha).toLocaleString('es-MX');
      const codeClass = l.code >= 200 && l.code < 300 ? 'success' : (l.code >= 400 ? 'danger' : 'secondary');
      return `<tr>
        <td class="small">${fecha}</td>
        <td><code>${l.endpoint}</code></td>
        <td class="text-center"><span class="badge bg-${codeClass}">${l.code}</span></td>
        <td class="text-end">${l.ms ?? '-'}</td>
        <td class="small text-danger">${l.error ? l.error.substring(0,120) : ''}</td>
      </tr>`;
    }).join('');
    logsCargados = true;
  } catch (e) {
    body.innerHTML = `<tr><td colspan="5" class="text-center text-danger py-3">Error al cargar: ${e.message}</td></tr>`;
  }
}
</script>

<div class="card mt-3">
  <div class="card-body">
    <h6>Sincronizar empleados</h6>
    <p class="text-body-secondary small mb-2">Encola todos los empleados activos hacia este checador (PIN = ID de empleado en Vita). El device los crea en su próximo polling; luego solo registras huella/rostro físicamente.</p>
    <form action="/checadores/<%= checador.ID_Checador %>/sincronizar" method="POST"
          onsubmit="return confirm('¿Encolar todos los empleados activos hacia este checador?')">
      <button type="submit" class="btn btn-success"><i class="bi bi-arrow-repeat me-1"></i>Sincronizar empleados</button>
    </form>
  </div>
</div>

<div class="mt-3">
  <a href="/checadores/<%= checador.ID_Checador %>/editar" class="btn btn-outline-primary"><i class="bi bi-pencil me-1"></i>Editar</a>
  <a href="/checadores" class="btn btn-outline-secondary">Volver</a>
</div>
