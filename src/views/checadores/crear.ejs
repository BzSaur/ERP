<% const edit = checador && checador.ID_Checador; %>
<div class="mb-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb mb-1">
      <li class="breadcrumb-item"><a href="/checadores">Checadores</a></li>
      <li class="breadcrumb-item active"><%= edit ? 'Editar' : 'Nuevo' %></li>
    </ol>
  </nav>
  <h4 class="mb-0"><%= edit ? 'Editar Checador' : 'Nuevo Checador' %></h4>
</div>

<div class="row">
  <div class="col-lg-7">
    <div class="card">
      <div class="card-body">
        <form action="<%= edit ? '/checadores/' + checador.ID_Checador : '/checadores' %>" method="POST">
          <% if (edit) { %><input type="hidden" name="_method" value="PUT"><% } %>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label">Número de Serie (SN) <span class="text-danger">*</span></label>
              <input type="text" class="form-control" name="Serial_Number"
                     value="<%= edit ? checador.Serial_Number : '' %>"
                     <%= edit ? 'readonly' : 'required' %>
                     placeholder="Ej: UDP3254603296">
              <small class="text-body-secondary">El SN identifica el device en /iclock. No se cambia tras crear.</small>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Nombre <span class="text-danger">*</span></label>
              <input type="text" class="form-control" name="Nombre" required
                     value="<%= edit ? checador.Nombre : '' %>" placeholder="Ej: RAM 1 Entrada">
            </div>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label">Planta <span class="text-danger">*</span></label>
              <select class="form-select" name="ID_Planta" required>
                <option value="">Seleccionar...</option>
                <% plantas.forEach(function(p) { %>
                  <option value="<%= p.ID_Planta %>" <%= edit && checador.ID_Planta === p.ID_Planta ? 'selected' : '' %>><%= p.Nombre %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Código de Ubicación</label>
              <input type="text" class="form-control" name="Ubicacion_Codigo"
                     value="<%= edit ? (checador.Ubicacion_Codigo || '') : '' %>" placeholder="Ej: RAM1">
              <small class="text-body-secondary">Mapea al código legacy de asistencia (RAM1/RAM2). Mayúsculas.</small>
            </div>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label">IP Local</label>
              <input type="text" class="form-control" name="IP_Local"
                     value="<%= edit ? (checador.IP_Local || '') : '' %>" placeholder="Ej: 192.168.1.50">
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Modelo</label>
              <input type="text" class="form-control" name="Modelo"
                     value="<%= edit ? (checador.Modelo || 'CLK-980') : 'CLK-980' %>">
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label">Detalle de Ubicación</label>
            <input type="text" class="form-control" name="Ubicacion_Detalle"
                   value="<%= edit ? (checador.Ubicacion_Detalle || '') : '' %>" placeholder="Ej: Acceso principal piso 1">
          </div>

          <% if (edit) { %>
          <div class="form-check mb-4">
            <input type="checkbox" class="form-check-input" name="Activo" id="activo" <%= checador.Activo ? 'checked' : '' %>>
            <label class="form-check-label" for="activo">Activo</label>
          </div>
          <% } %>

          <div class="d-flex gap-2">
            <a href="/checadores" class="btn btn-outline-secondary"><i class="bi bi-x-lg me-1"></i> Cancelar</a>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i> Guardar</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
