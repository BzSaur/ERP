<div class="mb-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb mb-1">
      <li class="breadcrumb-item"><a href="/checadores">Checadores</a></li>
      <li class="breadcrumb-item active">Huérfanas</li>
    </ol>
  </nav>
  <h4 class="mb-0">Checadas Huérfanas</h4>
  <p class="text-body-secondary mb-0">Checadas cuyo PIN no coincide con ningún empleado activo. Asigna manualmente.</p>
</div>

<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>PIN reportado</th>
            <th>Fecha/Hora</th>
            <th>Checador</th>
            <th>Asignar a empleado</th>
            <th class="text-end">Acción</th>
          </tr>
        </thead>
        <tbody>
          <% if (huerfanas && huerfanas.length > 0) { %>
            <% huerfanas.forEach(function(h) { %>
            <tr>
              <td><code><%= h.PIN_Reportado %></code></td>
              <td class="small"><%= new Date(h.Fecha_Hora).toLocaleString('es-MX') %></td>
              <td class="small">#<%= h.ID_Checador %></td>
              <td colspan="2">
                <form action="/checadores/huerfanas/<%= h.ID_Huerfana %>/resolver" method="POST" class="d-flex gap-2">
                  <select class="form-select form-select-sm" name="ID_Empleado" style="max-width:320px">
                    <option value="">-- Sin asignar (solo marcar resuelta) --</option>
                    <% empleados.forEach(function(e) { %>
                      <option value="<%= e.ID_Empleado %>"><%= e.ID_Empleado %> - <%= e.Nombre %> <%= e.Apellido_Paterno %> <%= e.Apellido_Materno || '' %></option>
                    <% }); %>
                  </select>
                  <button type="submit" class="btn btn-sm btn-primary">Resolver</button>
                </form>
              </td>
            </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="5" class="text-center text-body-secondary py-4">No hay checadas huérfanas pendientes</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
