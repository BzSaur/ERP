<!-- Header -->
<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 gap-2">
  <div>
    <h4 class="mb-1">Checadores</h4>
    <p class="text-body-secondary mb-0">Dispositivos biométricos por planta (push directo ADMS)</p>
  </div>
  <div class="d-flex gap-2">
    <a href="/checadores/plantas" class="btn btn-outline-secondary">
      <i class="bi bi-building me-1"></i> Plantas
    </a>
    <form action="/checadores/sincronizar-global" method="POST" class="d-inline"
          onsubmit="return confirm('¿Sincronizar TODOS los empleados en TODOS los checadores?')">
      <button type="submit" class="btn btn-outline-success">
        <i class="bi bi-arrow-repeat me-1"></i> Sincronizar Todo
      </button>
    </form>
    <a href="/checadores/crear" class="btn btn-primary">
      <i class="bi bi-plus-lg me-1"></i> Nuevo Checador
    </a>
  </div>
</div>

<!-- Avisos -->
<div class="row g-3 mb-4">
  <div class="col-md-6">
    <a href="/checadores/pendientes" class="text-decoration-none">
      <div class="card border-warning">
        <div class="card-body d-flex justify-content-between align-items-center">
          <span><i class="bi bi-question-circle text-warning me-2"></i>Pendientes de aprobación</span>
          <span class="badge bg-warning text-dark fs-6"><%= pendientesCount %></span>
        </div>
      </div>
    </a>
  </div>
  <div class="col-md-6">
    <a href="/checadores/huerfanas" class="text-decoration-none">
      <div class="card border-danger">
        <div class="card-body d-flex justify-content-between align-items-center">
          <span><i class="bi bi-person-x text-danger me-2"></i>Checadas huérfanas (PIN no resuelto)</span>
          <span class="badge bg-danger fs-6"><%= huerfanasCount %></span>
        </div>
      </div>
    </a>
  </div>
</div>

<!-- Tabla -->
<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Nombre</th>
            <th>Serial</th>
            <th>Planta</th>
            <th>Última conexión</th>
            <th class="text-center">Estado</th>
            <th class="text-center">Cmd. pend.</th>
            <th class="text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% if (checadores && checadores.length > 0) { %>
            <% checadores.forEach(function(c) { %>
            <tr>
              <td><i class="bi bi-fingerprint text-primary me-2"></i><strong><%= c.Nombre %></strong></td>
              <td><code><%= c.Serial_Number %></code></td>
              <td><%= c.planta ? c.planta.Nombre : '-' %></td>
              <td>
                <% if (c.Ultima_Conexion) { %>
                  <span class="small"><%= new Date(c.Ultima_Conexion).toLocaleString('es-MX') %></span>
                <% } else { %>
                  <span class="text-body-secondary small">Nunca</span>
                <% } %>
              </td>
              <td class="text-center">
                <% if (c.Activo) { %>
                  <span class="badge bg-success">Activo</span>
                <% } else { %>
                  <span class="badge bg-secondary">Inactivo</span>
                <% } %>
              </td>
              <td class="text-center">
                <% if (c._count.comandos > 0) { %>
                  <span class="badge bg-info"><%= c._count.comandos %></span>
                <% } else { %>
                  <span class="text-body-secondary">0</span>
                <% } %>
              </td>
              <td class="text-end">
                <a href="/checadores/<%= c.ID_Checador %>/diagnostico" class="btn btn-sm btn-outline-info" title="Diagnóstico">
                  <i class="bi bi-activity"></i>
                </a>
                <a href="/checadores/<%= c.ID_Checador %>/editar" class="btn btn-sm btn-outline-primary" title="Editar">
                  <i class="bi bi-pencil"></i>
                </a>
                <form action="/checadores/<%= c.ID_Checador %>/eliminar" method="POST" class="d-inline"
                      onsubmit="return confirm('¿Eliminar este checador?')">
                  <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
              </td>
            </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="7" class="text-center text-body-secondary py-4">No hay checadores registrados</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
