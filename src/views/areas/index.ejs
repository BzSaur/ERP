<!-- Header -->
<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 gap-2">
  <div>
    <h4 class="mb-1">Catálogo de Áreas</h4>
    <p class="text-body-secondary mb-0">Administra las áreas de la organización</p>
  </div>
  <% if (hasRole('ADMIN', 'Administrador', 'RH', 'Recursos Humanos', 'RECURSOS_HUMANOS', 'SuperAdministrador', 'SUPER_ADMIN')) { %>
  <a href="/areas/crear" class="btn btn-primary">
    <i class="bi bi-folder-plus me-2"></i>
    Nueva Área
  </a>
  <% } %>
</div>

<!-- Tabla de Áreas -->
<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Nombre del Área</th>
            <th>Tipo</th>
            <th>Descripción</th>
            <th class="text-center">Empleados</th>
            <th class="text-center">Puestos</th>
            <th class="text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% if (areas && areas.length > 0) { %>
            <% areas.forEach(function(area) { %>
            <tr>
              <td>
                <i class="bi bi-diagram-3 text-primary me-2"></i>
                <strong><%= area.Nombre_Area %></strong>
              </td>
              <td>
                <span class="badge bg-secondary"><%= area.Tipo_Area || 'Sin tipo' %></span>
              </td>
              <td><%= area.Descripcion || '-' %></td>
              <td class="text-center">
                <span class="badge bg-info"><%= area._count.empleados %></span>
              </td>
              <td class="text-center">
                <span class="badge bg-success"><%= area._count.puestos %></span>
              </td>
              <td class="text-end">
                <% if (hasRole('ADMIN', 'Administrador', 'RH', 'Recursos Humanos', 'RECURSOS_HUMANOS', 'SuperAdministrador', 'SUPER_ADMIN')) { %>
                <div class="d-inline-flex gap-2">
                  <a href="/areas/<%= area.ID_Area %>/editar" class="btn btn-sm btn-outline-primary" title="Editar">
                    <i class="bi bi-pencil"></i>
                  </a>

                  <form
                    action="/areas/<%= area.ID_Area %>/eliminar"
                    method="POST"
                    class="d-inline js-confirm-delete"
                    data-entity="el área <%= area.Nombre_Area %>"
                    data-alert-title="¿Seguro que desea eliminar esta área?"
                    data-alert-text="Se eliminará el área y sus puestos asociados. Esta acción no se puede deshacer."
                  >
                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar">
                      <i class="bi bi-trash"></i>
                    </button>
                  </form>
                </div>
                <% } else { %>
                <span class="text-body-secondary small">-</span>
                <% } %>
              </td>
            </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="6" class="text-center text-body-secondary py-4">No hay áreas registradas</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>