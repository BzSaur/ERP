<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 gap-2">
  <div>
    <h2 class="mb-1"><i class="bi bi-bug me-2"></i>Simulador de Checador <span class="badge bg-warning text-dark">QA</span></h2>
    <p class="text-body-secondary mb-0">Herramienta de prueba. Solo SuperAdmin.</p>
  </div>
  <a href="/configuracion" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-1"></i> Volver
  </a>
</div>

<% if (typeof messages !== 'undefined') { %>
  <% if (messages.success) { %>
    <div class="alert alert-success alert-dismissible fade show">
      <i class="bi bi-check-circle me-2"></i><%= messages.success %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
  <% if (messages.error) { %>
    <div class="alert alert-danger alert-dismissible fade show">
      <i class="bi bi-exclamation-circle me-2"></i><%= messages.error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
<% } %>

<div class="card">
  <div class="card-body">
    <form method="POST" action="/configuracion/_qa-checador" class="row g-3">
      <div class="col-md-6">
        <label class="form-label">Checador a simular</label>
        <select name="idChecador" class="form-select" required>
          <option value="">— Selecciona un checador —</option>
          <% checadores.forEach(c => { %>
            <option value="<%= c.ID_Checador %>">
              <%= c.Nombre %><%= c.planta?.Nombre ? ' · ' + c.planta.Nombre : '' %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="col-md-6">
        <label class="form-label">ID Empleado (PIN)</label>
        <input type="number" name="idEmpleado" class="form-control" placeholder="Ej. 101" required>
      </div>

      <div class="col-md-4">
        <label class="form-label">Fecha</label>
        <input type="date" name="fecha" class="form-control" required>
      </div>

      <div class="col-md-4">
        <label class="form-label">Hora (HH:mm)</label>
        <input type="time" name="hora" class="form-control" required>
      </div>

      <div class="col-md-4">
        <label class="form-label">Verificación (opcional)</label>
        <select name="verify" class="form-select">
          <option value="">— Ninguna —</option>
          <option value="1">Huella (1)</option>
          <option value="15">Rostro (15)</option>
          <option value="4">Tarjeta (4)</option>
        </select>
      </div>

      <div class="col-12">
        <button type="submit" class="btn btn-warning">
          <i class="bi bi-send me-1"></i> Inyectar checada
        </button>
      </div>
    </form>
  </div>
</div>
