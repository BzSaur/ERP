<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 gap-2">
  <div>
    <h2 class="mb-1"><i class="bi bi-sliders me-2"></i>Configuración de Nómina</h2>
    <p class="text-body-secondary mb-0">Controla tasas de interés, deducciones, IMSS, ISR y todos los parámetros del cálculo de nómina</p>
  </div>
  <a href="/configuracion" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-1"></i> Volver
  </a>
</div>

<% if (typeof messages !== 'undefined') { %>
  <% if (messages.success) { %>
    <div class="alert alert-success alert-dismissible fade show">
      <i class="bi bi-check-circle me-2"></i><%= messages.success %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
  <% if (messages.error) { %>
    <div class="alert alert-danger alert-dismissible fade show">
      <i class="bi bi-exclamation-circle me-2"></i><%= messages.error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
<% } %>

<!-- Resumen rápido de configuración activa -->
<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <div class="card border-<%= configMap['CALCULAR_IMSS']?.Valor === 'true' ? 'success' : 'secondary' %>">
      <div class="card-body text-center py-3">
        <i class="bi bi-shield-check fs-3 text-<%= configMap['CALCULAR_IMSS']?.Valor === 'true' ? 'success' : 'secondary' %>"></i>
        <p class="mb-0 mt-1 fw-bold">IMSS</p>
        <small class="text-body-secondary">
          <%= configMap['CALCULAR_IMSS']?.Valor === 'true' ? (configMap['TASA_IMSS_EMPLEADO']?.Valor || '2.475') + '%' : 'Desactivado' %>
        </small>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card border-<%= configMap['CALCULAR_ISR']?.Valor === 'true' ? 'success' : 'secondary' %>">
      <div class="card-body text-center py-3">
        <i class="bi bi-receipt fs-3 text-<%= configMap['CALCULAR_ISR']?.Valor === 'true' ? 'success' : 'secondary' %>"></i>
        <p class="mb-0 mt-1 fw-bold">ISR</p>
        <small class="text-body-secondary">
          <%= configMap['CALCULAR_ISR']?.Valor === 'true' ? (configMap['TASA_ISR']?.Valor || '0') + '%' : 'Desactivado' %>
        </small>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card border-<%= configMap['PRESTAMOS_ACTIVO']?.Valor === 'true' ? 'warning' : 'secondary' %>">
      <div class="card-body text-center py-3">
        <i class="bi bi-bank fs-3 text-<%= configMap['PRESTAMOS_ACTIVO']?.Valor === 'true' ? 'warning' : 'secondary' %>"></i>
        <p class="mb-0 mt-1 fw-bold">Préstamos</p>
        <small class="text-body-secondary">
          Interés: <%= configMap['PRESTAMOS_TASA_INTERES']?.Valor || '0' %>%
        </small>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card border-info">
      <div class="card-body text-center py-3">
        <i class="bi bi-star fs-3 text-info"></i>
        <p class="mb-0 mt-1 fw-bold">Bono Puntualidad</p>
        <small class="text-body-secondary">
          $<%= configMap['BONO_PUNTUALIDAD_MONTO']?.Valor || '50' %>
        </small>
      </div>
    </div>
  </div>
</div>

<!-- Contenido por categorías -->
<div class="accordion" id="accordionConfig">
  <% const catKeys = Object.keys(categorias); %>
  <% catKeys.forEach((catKey, index) => { %>
    <% const cat = categorias[catKey]; %>
    <% const clavesCategoria = cat.claves.filter(c => configMap[c]); %>
    <% if (clavesCategoria.length > 0) { %>
    <div class="accordion-item">
      <h2 class="accordion-header" id="heading-<%= catKey %>">
        <button class="accordion-button <%= catKey === 'deducciones' || catKey === 'prestamos' ? '' : 'collapsed' %>" 
                type="button" data-bs-toggle="collapse" data-bs-target="#collapse-<%= catKey %>">
          <i class="bi <%= cat.icono %> me-2"></i>
          <strong><%= cat.titulo %></strong>
          <span class="badge bg-secondary ms-2"><%= clavesCategoria.length %></span>
        </button>
      </h2>
      <div id="collapse-<%= catKey %>" 
           class="accordion-collapse collapse <%= catKey === 'deducciones' || catKey === 'prestamos' ? 'show' : '' %>" 
           data-bs-parent="#accordionConfig">
        <div class="accordion-body">
          <form action="/configuracion/nomina/categoria?_method=POST" method="POST">
            <div class="table-responsive">
              <table class="table table-hover mb-0">
                <thead class="table-light">
                  <tr>
                    <th style="width: 25%;">Parámetro</th>
                    <th style="width: 35%;">Descripción</th>
                    <th style="width: 15%;">Tipo</th>
                    <th style="width: 20%;">Valor</th>
                    <th style="width: 5%;">Acción</th>
                  </tr>
                </thead>
                <tbody>
                  <% clavesCategoria.forEach(clave => { %>
                    <% const cfg = configMap[clave]; %>
                    <% if (cfg) { %>
                    <tr>
                      <td>
                        <code class="text-primary"><%= cfg.Clave %></code>
                      </td>
                      <td>
                        <small class="text-body-secondary"><%= cfg.Descripcion || '-' %></small>
                      </td>
                      <td>
                        <span class="badge bg-<%= cfg.Tipo_Dato === 'BOOLEAN' ? 'info' : cfg.Tipo_Dato === 'DECIMAL' ? 'warning' : cfg.Tipo_Dato === 'INT' ? 'primary' : 'secondary' %>">
                          <%= cfg.Tipo_Dato %>
                        </span>
                      </td>
                      <td>
                        <% if (cfg.Tipo_Dato === 'BOOLEAN') { %>
                          <select name="<%= cfg.Clave %>" class="form-select form-select-sm">
                            <option value="true" <%= cfg.Valor === 'true' ? 'selected' : '' %>>Sí (Activado)</option>
                            <option value="false" <%= cfg.Valor === 'false' ? 'selected' : '' %>>No (Desactivado)</option>
                          </select>
                        <% } else if (cfg.Tipo_Dato === 'INT' || cfg.Tipo_Dato === 'DECIMAL') { %>
                          <div class="input-group input-group-sm">
                            <input type="number" 
                                   name="<%= cfg.Clave %>" 
                                   value="<%= cfg.Valor %>" 
                                   class="form-control form-control-sm"
                                   step="<%= cfg.Tipo_Dato === 'DECIMAL' ? '0.001' : '1' %>"
                                   <% if (clave.includes('TASA') || clave.includes('PCT')) { %>min="0" max="100"<% } %>>
                            <% if (clave.includes('TASA') || clave.includes('PCT')) { %>
                              <span class="input-group-text">%</span>
                            <% } else if (clave.includes('MONTO') || clave.includes('UMA') || clave.includes('SALARIO_MINIMO')) { %>
                              <span class="input-group-text">$</span>
                            <% } %>
                          </div>
                        <% } else { %>
                          <input type="text" 
                                 name="<%= cfg.Clave %>" 
                                 value="<%= cfg.Valor %>" 
                                 class="form-control form-control-sm">
                        <% } %>
                      </td>
                      <td>
                        <% if (cfg.UpdatedBy) { %>
                          <small class="text-body-secondary" title="Modificado por <%= cfg.UpdatedBy %>">
                            <i class="bi bi-pencil-square"></i>
                          </small>
                        <% } %>
                      </td>
                    </tr>
                    <% } %>
                  <% }) %>
                </tbody>
              </table>
            </div>
            <div class="text-end mt-3">
              <button type="submit" class="btn btn-primary btn-sm">
                <i class="bi bi-save me-1"></i> Guardar <%= cat.titulo %>
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
    <% } %>
  <% }) %>
</div>

<!-- Nota informativa -->
<div class="card mt-4 border-info">
  <div class="card-body">
    <h6 class="card-title"><i class="bi bi-info-circle me-1"></i> Nota sobre el cálculo de nómina</h6>
    <ul class="mb-0 small">
      <li><strong>Salario semanal</strong> = Salario diario × 7 (incluye domingo de descanso, LFT Art. 69/72)</li>
      <li><strong>IMSS/ISR</strong>: Solo se aplican si están <strong>activados</strong>. Para pruebas, desactívalos o coloca la tasa en 0%.</li>
      <li><strong>Tasa de interés en préstamos</strong>: Se aplica al saldo pendiente como interés anual dividido entre 52 semanas. Coloca 0 para que no haya interés.</li>
      <li><strong>Horas dobles</strong>: Se pagan al doble del salario hora. <strong>Horas triples</strong>: al triple.</li>
      <li>Todos los cambios aquí <strong>aplican al siguiente cálculo de nómina</strong>. Las nóminas ya calculadas no se modifican automáticamente.</li>
    </ul>
  </div>
</div>
