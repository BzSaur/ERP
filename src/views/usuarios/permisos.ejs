<!-- Header -->
<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 gap-2">
  <div>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-1">
        <li class="breadcrumb-item"><a href="/usuarios">Usuarios</a></li>
        <li class="breadcrumb-item active">Permisos</li>
      </ol>
    </nav>
    <h2 class="mb-0"><i class="bi bi-shield-lock me-2"></i>Permisos de Visibilidad</h2>
    <p class="text-body-secondary mb-0 small"><%= usuario.Nombre_Completo %> · <%= usuario.rol ? usuario.rol.Nombre_Rol : '' %></p>
  </div>
  <a href="/usuarios" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-1"></i> Volver
  </a>
</div>

<% if (typeof error !== 'undefined' && error) { %>
<div class="alert alert-danger alert-dismissible fade show" role="alert">
  <i class="bi bi-exclamation-triangle me-2"></i><%= error %>
  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
<% } %>

<div class="alert alert-info d-flex align-items-start gap-2">
  <i class="bi bi-info-circle fs-5"></i>
  <div>
    Si no seleccionas nada, el usuario ve <strong>todo</strong>. Si seleccionas plantas <em>y</em> áreas,
    solo verá lo que cumpla <strong>ambas</strong> (ej. área SISTEMAS <em>en</em> esa planta). Si seleccionas
    solo una dimensión, únicamente esa restringe.
  </div>
</div>

<form method="POST" action="/usuarios/<%= usuario.ID_Usuario %>/permisos">
  <div class="row g-4">
    <!-- Plantas -->
    <div class="col-md-6">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <span class="fw-semibold"><i class="bi bi-building me-2"></i>Plantas / Checadores</span>
          <div>
            <button type="button" class="btn btn-sm btn-link p-0 me-2 btn-toggle-all" data-grupo="plantas" data-estado="1">Todas</button>
            <button type="button" class="btn btn-sm btn-link p-0 btn-toggle-all" data-grupo="plantas" data-estado="0">Ninguna</button>
          </div>
        </div>
        <div class="card-body">
          <% if (plantas.length === 0) { %>
            <p class="text-body-secondary mb-0">No hay plantas registradas.</p>
          <% } %>
          <% plantas.forEach(function(p) { %>
          <div class="form-check">
            <input class="form-check-input chk-plantas" type="checkbox" name="plantas" value="<%= p.ID_Planta %>"
                   id="planta-<%= p.ID_Planta %>" <%= plantasAsignadas.has(p.ID_Planta) ? 'checked' : '' %>>
            <label class="form-check-label" for="planta-<%= p.ID_Planta %>"><%= p.Nombre %></label>
          </div>
          <% }); %>
        </div>
      </div>
    </div>

    <!-- Áreas -->
    <div class="col-md-6">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <span class="fw-semibold"><i class="bi bi-diagram-3 me-2"></i>Áreas</span>
          <div>
            <button type="button" class="btn btn-sm btn-link p-0 me-2 btn-toggle-all" data-grupo="areas" data-estado="1">Todas</button>
            <button type="button" class="btn btn-sm btn-link p-0 btn-toggle-all" data-grupo="areas" data-estado="0">Ninguna</button>
          </div>
        </div>
        <div class="card-body" style="max-height: 400px; overflow-y: auto;">
          <% if (areas.length === 0) { %>
            <p class="text-body-secondary mb-0">No hay áreas registradas.</p>
          <% } %>
          <% areas.forEach(function(a) { %>
          <div class="form-check">
            <input class="form-check-input chk-areas" type="checkbox" name="areas" value="<%= a.ID_Area %>"
                   id="area-<%= a.ID_Area %>" <%= areasAsignadas.has(a.ID_Area) ? 'checked' : '' %>>
            <label class="form-check-label" for="area-<%= a.ID_Area %>"><%= a.Nombre_Area %></label>
          </div>
          <% }); %>
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2 mt-4">
    <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle me-1"></i>Guardar</button>
    <a href="/usuarios" class="btn btn-outline-secondary">Cancelar</a>
  </div>
</form>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.btn-toggle-all').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var grupo = btn.getAttribute('data-grupo');
        var estado = btn.getAttribute('data-estado') === '1';
        document.querySelectorAll('.chk-' + grupo).forEach(function (c) { c.checked = estado; });
      });
    });
  });
</script>
