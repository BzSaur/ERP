<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 gap-2">
  <div>
    <h2 class="mb-1">Nuevo Horario</h2>
    <p class="text-body-secondary mb-0">Agregar un nuevo tipo de horario</p>
  </div>
  <a href="/horarios" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-1"></i> Volver
  </a>
</div>

<% if (typeof messages !== 'undefined' && messages.error) { %>
  <div class="alert alert-danger alert-dismissible fade show">
    <i class="bi bi-exclamation-circle me-2"></i><%= messages.error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<div class="card">
  <div class="card-body">
    <form action="/horarios" method="POST">
      <div class="row g-3">
        <div class="col-md-6">
          <label for="Nombre_Horario" class="form-label">Nombre del Horario *</label>
          <input type="text" class="form-control" id="Nombre_Horario" 
                 name="Nombre_Horario" required maxlength="30"
                 placeholder="Ej: Tiempo Completo">
        </div>
        
        <div class="col-6 col-md-3">
          <label for="Dias_Semana" class="form-label">Días por Semana *</label>
          <input type="number" class="form-control" id="Dias_Semana"
                 name="Dias_Semana" min="1" max="7" required value="6" oninput="calcSemana()">
        </div>

        <div class="col-6 col-md-3">
          <label for="Horas_Jornada" class="form-label">Horas por Jornada (día) *</label>
          <input type="number" class="form-control" id="Horas_Jornada"
                 name="Horas_Jornada" min="1" max="24" required value="8" oninput="calcSemana()">
        </div>

        <div class="col-6 col-md-3">
          <label for="Horas_Semana" class="form-label">Horas por Semana</label>
          <input type="number" class="form-control bg-light" id="Horas_Semana"
                 name="Horas_Semana" min="1" max="168" readonly value="48">
          <small class="text-body-secondary">jornada × días</small>
        </div>

        <div class="col-md-12">
          <label for="Descripcion" class="form-label">Descripción</label>
          <textarea class="form-control" id="Descripcion" 
                    name="Descripcion" rows="3" maxlength="255"
                    placeholder="Descripción del tipo de horario..."></textarea>
        </div>
      </div>
      
      <hr class="my-4">
      
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-check-lg me-1"></i> Guardar
        </button>
        <a href="/horarios" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<script>
function calcSemana() {
  const j = parseFloat(document.getElementById('Horas_Jornada').value) || 0;
  const d = parseInt(document.getElementById('Dias_Semana').value) || 0;
  document.getElementById('Horas_Semana').value = Math.round(j * d * 100) / 100;
}
</script>
