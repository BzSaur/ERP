<!-- Header -->
<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 gap-2">
  <div>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-1">
        <li class="breadcrumb-item"><a href="/empleados">Empleados</a></li>
        <li class="breadcrumb-item active">Nuevo</li>
      </ol>
    </nav>
    <h4 class="mb-0">Registrar Nuevo Empleado</h4>
  </div>
</div>

<!-- Formulario -->
<form action="/empleados" method="POST"
      class="js-confirm-create"
      data-entity="el empleado"
      data-alert-title="¿Desea registrar este empleado?"
      data-alert-text="Se creará el empleado con la información capturada.">
  <div class="row g-4">
    <!-- Datos Personales -->
    <div class="col-lg-6">
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">
            <i class="bi bi-person me-2"></i>
            Datos Personales
          </h5>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label">Nombre(s) <span class="text-danger">*</span></label>
              <input type="text" class="form-control" name="Nombre" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Apellido Paterno <span class="text-danger">*</span></label>
              <input type="text" class="form-control" name="Apellido_Paterno" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Apellido Materno</label>
              <input type="text" class="form-control" name="Apellido_Materno">
            </div>
            <div class="col-md-6">
              <label class="form-label">Fecha de Nacimiento</label>
              <input type="date" class="form-control" name="Fecha_Nacimiento">
            </div>
            <div class="col-md-6">
              <label class="form-label">Nacionalidad <span class="text-danger">*</span></label>
              <select class="form-select" name="ID_Nacionalidad" required>
                <option value="">Seleccionar...</option>
                <% nacionalidades.forEach(function(n) { %>
                  <option value="<%= n.ID_Nacionalidad %>"><%= n.Nombre_Nacionalidad %></option>
                <% }); %>
              </select>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Documentos -->
    <div class="col-lg-6">
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">
            <i class="bi bi-card-text me-2"></i>
            Documentos de Identidad
          </h5>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Tipo de Documento <span class="text-danger">*</span></label>
              <select class="form-select" name="Tipo_Documento" required>
                <option value="">Seleccionar...</option>
                <option value="INE">INE</option>
                <option value="PASAPORTE">Pasaporte</option>
                <option value="CEDULA">Cédula Profesional</option>
                <option value="OTRO">Otro</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Número de Documento <span class="text-danger">*</span></label>
              <input type="text" class="form-control" name="Documento_Identidad" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">RFC</label>
              <input type="text" class="form-control" name="RFC" maxlength="13" placeholder="XXXX000000XXX">
            </div>
            <div class="col-md-6">
              <label class="form-label">NSS (Número Seguro Social)</label>
              <input type="text" class="form-control" name="NSS" maxlength="20">
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Información de Contacto -->
    <div class="col-lg-6">
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">
            <i class="bi bi-envelope me-2"></i>
            Información de Contacto
          </h5>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Email Personal</label>
              <input type="email" class="form-control" name="Email_Personal" placeholder="ejemplo@correo.com">
            </div>
            <div class="col-md-6">
              <label class="form-label">Email Corporativo</label>
              <input type="email" class="form-control" name="Email_Corporativo" placeholder="ejemplo@empresa.com">
            </div>
            <div class="col-md-6">
              <label class="form-label">Teléfono Celular</label>
              <input type="tel" class="form-control" name="Telefono_Celular" placeholder="10 dígitos">
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Contacto de Emergencia -->
    <div class="col-lg-6">
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">
            <i class="bi bi-hospital me-2"></i>
            Contacto de Emergencia
          </h5>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label">Nombre Completo</label>
              <input type="text" class="form-control" name="Nombre_Emergencia" placeholder="Nombre del contacto de emergencia">
            </div>
            <div class="col-md-6">
              <label class="form-label">Parentesco</label>
              <select class="form-select" name="Parentesco_Emergencia">
                <option value="">Seleccionar...</option>
                <option value="Cónyuge">Cónyuge</option>
                <option value="Padre/Madre">Padre/Madre</option>
                <option value="Hijo/Hija">Hijo/Hija</option>
                <option value="Hermano/Hermana">Hermano/Hermana</option>
                <option value="Tío/Tía">Tío/Tía</option>
                <option value="Abuelo/Abuela">Abuelo/Abuela</option>
                <option value="Amigo/Amiga">Amigo/Amiga</option>
                <option value="Otro">Otro</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Teléfono de Emergencia</label>
              <input type="tel" class="form-control" name="Telefono_Emergencia" placeholder="10 dígitos">
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Dirección -->
    <div class="col-12">
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">
            <i class="bi bi-geo-alt me-2"></i>
            Dirección
          </h5>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Calle</label>
              <input type="text" class="form-control" name="Calle" placeholder="Nombre de la calle">
            </div>
            <div class="col-6 col-md-3">
              <label class="form-label">Número Exterior</label>
              <input type="text" class="form-control" name="Numero_Exterior" placeholder="Ej: 123">
            </div>
            <div class="col-6 col-md-3">
              <label class="form-label">Número Interior</label>
              <input type="text" class="form-control" name="Numero_Interior" placeholder="Opcional">
            </div>
            <div class="col-md-6">
              <label class="form-label">Colonia</label>
              <input type="text" class="form-control" name="Colonia" placeholder="Colonia o fraccionamiento">
            </div>
            <div class="col-md-6">
              <label class="form-label">Ciudad</label>
              <input type="text" class="form-control" name="Ciudad" placeholder="Ciudad o municipio">
            </div>
            <div class="col-md-6">
              <label class="form-label">Estado</label>
              <select class="form-select" name="Entidad_Federativa">
                <option value="">Seleccionar...</option>
                <option value="Aguascalientes">Aguascalientes</option>
                <option value="Baja California">Baja California</option>
                <option value="Baja California Sur">Baja California Sur</option>
                <option value="Campeche">Campeche</option>
                <option value="Chiapas">Chiapas</option>
                <option value="Chihuahua">Chihuahua</option>
                <option value="Ciudad de México">Ciudad de México</option>
                <option value="Coahuila">Coahuila</option>
                <option value="Colima">Colima</option>
                <option value="Durango">Durango</option>
                <option value="Guanajuato">Guanajuato</option>
                <option value="Guerrero">Guerrero</option>
                <option value="Hidalgo">Hidalgo</option>
                <option value="Jalisco">Jalisco</option>
                <option value="México">México</option>
                <option value="Michoacán">Michoacán</option>
                <option value="Morelos">Morelos</option>
                <option value="Nayarit">Nayarit</option>
                <option value="Nuevo León">Nuevo León</option>
                <option value="Oaxaca">Oaxaca</option>
                <option value="Puebla">Puebla</option>
                <option value="Querétaro">Querétaro</option>
                <option value="Quintana Roo">Quintana Roo</option>
                <option value="San Luis Potosí">San Luis Potosí</option>
                <option value="Sinaloa">Sinaloa</option>
                <option value="Sonora">Sonora</option>
                <option value="Tabasco">Tabasco</option>
                <option value="Tamaulipas">Tamaulipas</option>
                <option value="Tlaxcala">Tlaxcala</option>
                <option value="Veracruz">Veracruz</option>
                <option value="Yucatán">Yucatán</option>
                <option value="Zacatecas">Zacatecas</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Código Postal</label>
              <input type="text" class="form-control" name="Codigo_Postal" placeholder="5 dígitos" maxlength="5">
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Información Laboral -->
    <div class="col-lg-6">
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">
            <i class="bi bi-briefcase me-2"></i>
            Información Laboral
          </h5>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Área <span class="text-danger">*</span></label>
              <select class="form-select" name="ID_Area" id="selectArea" required>
                <option value="">Seleccionar...</option>
                <% areas.forEach(function(a) { %>
                  <option value="<%= a.ID_Area %>"><%= a.Nombre_Area %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Puesto <span class="text-danger">*</span></label>
              <select class="form-select" name="ID_Puesto" id="selectPuesto" required>
                <option value="">Seleccionar área primero...</option>
                <% puestos.forEach(function(p) { %>
                  <option value="<%= p.ID_Puesto %>" data-area="<%= p.ID_Area %>"><%= p.Nombre_Puesto %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Tipo de Horario <span class="text-danger">*</span></label>
              <select class="form-select" name="ID_Tipo_Horario" required>
                <option value="">Seleccionar...</option>
                <% tiposHorario.forEach(function(t) { %>
                  <option value="<%= t.ID_Tipo_Horario %>"><%= t.Nombre_Horario %><% if (t.Horas_Semana) { %> (<%= t.Horas_Semana %> hrs/sem)<% } %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Estatus <span class="text-danger">*</span></label>
              <select class="form-select" name="ID_Estatus" required>
                <% estatuses.forEach(function(e) { %>
                  <option value="<%= e.ID_Estatus %>" <%= e.Nombre_Estatus === 'ACTIVO' ? 'selected' : '' %>><%= e.Nombre_Estatus %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Fecha de Ingreso <span class="text-danger">*</span></label>
              <input type="date" class="form-control" name="Fecha_Ingreso" value="<%= new Date().toISOString().split('T')[0] %>" required>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Salarios -->
    <div class="col-lg-6">
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">
            <i class="bi bi-currency-dollar me-2"></i>
            Información Salarial
          </h5>
        </div>
        <div class="card-body">
          <div class="alert alert-info small mb-3">
            <i class="bi bi-info-circle me-1"></i>
            <strong>Nota:</strong> Al seleccionar un puesto, el salario se cargará automáticamente según la plantilla. 
            Puede modificarlo si es necesario.
          </div>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Salario Mensual</label>
              <div class="input-group">
                <span class="input-group-text">$</span>
                <input type="number" step="0.01" class="form-control" name="Salario_Mensual" id="salarioMensual" placeholder="Se carga del puesto">
              </div>
              <small class="text-body-secondary">Base mensual</small>
            </div>
            <div class="col-md-6">
              <label class="form-label">Salario Diario</label>
              <div class="input-group">
                <span class="input-group-text">$</span>
                <input type="number" step="0.01" class="form-control" name="Salario_Diario" id="salarioDiario" readonly>
              </div>
              <small class="text-body-secondary">Se calcula automáticamente</small>
            </div>
            <div class="col-md-6">
              <label class="form-label">Salario por Hora</label>
              <div class="input-group">
                <span class="input-group-text">$</span>
                <input type="number" step="0.01" class="form-control" name="Salario_Hora" id="salarioHora" readonly>
              </div>
              <small class="text-body-secondary">Se calcula automáticamente</small>
            </div>
            <div class="col-md-6">
              <label class="form-label">Horas Semanales</label>
              <input type="number" class="form-control" name="Horas_Semanales_Contratadas" value="48">
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Botones -->
  <div class="d-flex justify-content-end gap-2 mt-4">
    <a href="/empleados" class="btn btn-outline-secondary">
      <i class="bi bi-x-lg me-1"></i> Cancelar
    </a>
    <button type="submit" class="btn btn-primary">
      <i class="bi bi-check-lg me-1"></i> Guardar Empleado
    </button>
  </div>
</form>

<script>
  // Datos de puestos con salarios
  const puestosData = {
    <% puestos.forEach(function(p) { %>
    '<%= p.ID_Puesto %>': { 
      area: '<%= p.ID_Area %>', 
      salarioBase: <%= p.Salario_Base_Referencia || 0 %>,
      salarioHora: <%= p.Salario_Hora_Referencia || 0 %>
    },
    <% }); %>
  };

  // Filtrar puestos por área
  document.getElementById('selectArea').addEventListener('change', function() {
    const areaId = this.value;
    const puestoSelect = document.getElementById('selectPuesto');
    const options = puestoSelect.querySelectorAll('option[data-area]');
    
    puestoSelect.value = '';
    limpiarSalarios();
    
    options.forEach(option => {
      if (!areaId || option.dataset.area === areaId) {
        option.style.display = '';
      } else {
        option.style.display = 'none';
      }
    });
  });

  // Cargar salario al seleccionar puesto
  document.getElementById('selectPuesto').addEventListener('change', function() {
    const puestoId = this.value;
    const salarioMensualInput = document.getElementById('salarioMensual');
    const salarioDiarioInput = document.getElementById('salarioDiario');
    const salarioHoraInput = document.getElementById('salarioHora');
    
    if (puestoId && puestosData[puestoId]) {
      const puesto = puestosData[puestoId];
      
      if (puesto.salarioBase > 0) {
        salarioMensualInput.value = puesto.salarioBase.toFixed(2);
        calcularSalarios(puesto.salarioBase);
      } else {
        limpiarSalarios();
      }
    } else {
      limpiarSalarios();
    }
  });

  // Recalcular al cambiar salario mensual
  document.getElementById('salarioMensual').addEventListener('input', function() {
    const mensual = parseFloat(this.value) || 0;
    calcularSalarios(mensual);
  });

  function calcularSalarios(mensual) {
    const diario = mensual / 30;
    const hora = diario / 8;
    
    document.getElementById('salarioDiario').value = diario.toFixed(2);
    document.getElementById('salarioHora').value = hora.toFixed(2);
  }

  function limpiarSalarios() {
    document.getElementById('salarioMensual').value = '';
    document.getElementById('salarioDiario').value = '';
    document.getElementById('salarioHora').value = '';
  }
</script>