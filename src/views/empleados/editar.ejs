<!-- Header -->
<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 gap-2">
  <div>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-1">
        <li class="breadcrumb-item"><a href="/empleados">Empleados</a></li>
        <li class="breadcrumb-item"><a href="/empleados/<%= empleado.ID_Empleado %>"><%= empleado.Nombre %></a></li>
        <li class="breadcrumb-item active">Editar</li>
      </ol>
    </nav>
    <h4 class="mb-0">Editar Empleado</h4>
  </div>
</div>

<!-- Formulario -->
<form action="/empleados/<%= empleado.ID_Empleado %>" method="POST">
  <div class="row g-4">
    <!-- Datos Personales -->
    <div class="col-lg-6">
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">
            <i class="bi bi-person me-2"></i>
            Datos Personales
          </h5>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label">Nombre(s) <span class="text-danger">*</span></label>
              <input type="text" class="form-control" name="Nombre" value="<%= empleado.Nombre %>" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Apellido Paterno <span class="text-danger">*</span></label>
              <input type="text" class="form-control" name="Apellido_Paterno" value="<%= empleado.Apellido_Paterno %>" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Apellido Materno</label>
              <input type="text" class="form-control" name="Apellido_Materno" value="<%= empleado.Apellido_Materno || '' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label">Fecha de Nacimiento</label>
              <input type="date" class="form-control" name="Fecha_Nacimiento" value="<%= empleado.Fecha_Nacimiento ? new Date(empleado.Fecha_Nacimiento).toISOString().split('T')[0] : '' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label">Nacionalidad <span class="text-danger">*</span></label>
              <select class="form-select" name="ID_Nacionalidad" required>
                <% nacionalidades.forEach(function(n) { %>
                  <option value="<%= n.ID_Nacionalidad %>" <%= n.ID_Nacionalidad === empleado.ID_Nacionalidad ? 'selected' : '' %>><%= n.Nombre_Nacionalidad %></option>
                <% }); %>
              </select>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Documentos -->
    <div class="col-lg-6">
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">
            <i class="bi bi-card-text me-2"></i>
            Documentos de Identidad
          </h5>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Tipo de Documento <span class="text-danger">*</span></label>
              <select class="form-select" name="Tipo_Documento" required>
                <option value="INE" <%= empleado.Tipo_Documento === 'INE' ? 'selected' : '' %>>INE</option>
                <option value="PASAPORTE" <%= empleado.Tipo_Documento === 'PASAPORTE' ? 'selected' : '' %>>Pasaporte</option>
                <option value="CEDULA" <%= empleado.Tipo_Documento === 'CEDULA' ? 'selected' : '' %>>Cédula Profesional</option>
                <option value="OTRO" <%= empleado.Tipo_Documento === 'OTRO' ? 'selected' : '' %>>Otro</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Número de Documento <span class="text-danger">*</span></label>
              <input type="text" class="form-control" name="Documento_Identidad" value="<%= empleado.Documento_Identidad %>" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">RFC</label>
              <input type="text" class="form-control" name="RFC" maxlength="13" value="<%= empleado.RFC || '' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label">NSS</label>
              <input type="text" class="form-control" name="NSS" maxlength="20" value="<%= empleado.NSS || '' %>">
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Información de Contacto -->
    <div class="col-lg-6">
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">
            <i class="bi bi-envelope me-2"></i>
            Información de Contacto
          </h5>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Email Personal</label>
              <input type="email" class="form-control" name="Email_Personal" value="<%= empleado.Email_Personal || '' %>" placeholder="ejemplo@correo.com">
            </div>
            <div class="col-md-6">
              <label class="form-label">Email Corporativo</label>
              <input type="email" class="form-control" name="Email_Corporativo" value="<%= empleado.Email_Corporativo || '' %>" placeholder="ejemplo@empresa.com">
            </div>
            <div class="col-md-6">
              <label class="form-label">Teléfono Celular</label>
              <input type="tel" class="form-control" name="Telefono_Celular" value="<%= empleado.Telefono_Celular || '' %>" placeholder="10 dígitos">
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Contacto de Emergencia -->
    <div class="col-lg-6">
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">
            <i class="bi bi-hospital me-2"></i>
            Contacto de Emergencia
          </h5>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label">Nombre Completo</label>
              <input type="text" class="form-control" name="Nombre_Emergencia" value="<%= empleado.Nombre_Emergencia || '' %>" placeholder="Nombre del contacto de emergencia">
            </div>
            <div class="col-md-6">
              <label class="form-label">Parentesco</label>
              <select class="form-select" name="Parentesco_Emergencia">
                <option value="">Seleccionar...</option>
                <option value="Cónyuge" <%= empleado.Parentesco_Emergencia === 'Cónyuge' ? 'selected' : '' %>>Cónyuge</option>
                <option value="Padre/Madre" <%= empleado.Parentesco_Emergencia === 'Padre/Madre' ? 'selected' : '' %>>Padre/Madre</option>
                <option value="Hijo/Hija" <%= empleado.Parentesco_Emergencia === 'Hijo/Hija' ? 'selected' : '' %>>Hijo/Hija</option>
                <option value="Hermano/Hermana" <%= empleado.Parentesco_Emergencia === 'Hermano/Hermana' ? 'selected' : '' %>>Hermano/Hermana</option>
                <option value="Tío/Tía" <%= empleado.Parentesco_Emergencia === 'Tío/Tía' ? 'selected' : '' %>>Tío/Tía</option>
                <option value="Abuelo/Abuela" <%= empleado.Parentesco_Emergencia === 'Abuelo/Abuela' ? 'selected' : '' %>>Abuelo/Abuela</option>
                <option value="Amigo/Amiga" <%= empleado.Parentesco_Emergencia === 'Amigo/Amiga' ? 'selected' : '' %>>Amigo/Amiga</option>
                <option value="Otro" <%= empleado.Parentesco_Emergencia === 'Otro' ? 'selected' : '' %>>Otro</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Teléfono de Emergencia</label>
              <input type="tel" class="form-control" name="Telefono_Emergencia" value="<%= empleado.Telefono_Emergencia || '' %>" placeholder="10 dígitos">
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Dirección -->
    <div class="col-12">
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">
            <i class="bi bi-geo-alt me-2"></i>
            Dirección
          </h5>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Calle</label>
              <input type="text" class="form-control" name="Calle" value="<%= empleado.Calle || '' %>" placeholder="Nombre de la calle">
            </div>
            <div class="col-6 col-md-3">
              <label class="form-label">Número Exterior</label>
              <input type="text" class="form-control" name="Numero_Exterior" value="<%= empleado.Numero_Exterior || '' %>" placeholder="Ej: 123">
            </div>
            <div class="col-6 col-md-3">
              <label class="form-label">Número Interior</label>
              <input type="text" class="form-control" name="Numero_Interior" value="<%= empleado.Numero_Interior || '' %>" placeholder="Opcional">
            </div>
            <div class="col-md-6">
              <label class="form-label">Colonia</label>
              <input type="text" class="form-control" name="Colonia" value="<%= empleado.Colonia || '' %>" placeholder="Colonia o fraccionamiento">
            </div>
            <div class="col-md-6">
              <label class="form-label">Ciudad</label>
              <input type="text" class="form-control" name="Ciudad" value="<%= empleado.Ciudad || '' %>" placeholder="Ciudad o municipio">
            </div>
            <div class="col-md-6">
              <label class="form-label">Estado</label>
              <select class="form-select" name="Entidad_Federativa">
                <option value="">Seleccionar...</option>
                <option value="Aguascalientes" <%= empleado.Entidad_Federativa === 'Aguascalientes' ? 'selected' : '' %>>Aguascalientes</option>
                <option value="Baja California" <%= empleado.Entidad_Federativa === 'Baja California' ? 'selected' : '' %>>Baja California</option>
                <option value="Baja California Sur" <%= empleado.Entidad_Federativa === 'Baja California Sur' ? 'selected' : '' %>>Baja California Sur</option>
                <option value="Campeche" <%= empleado.Entidad_Federativa === 'Campeche' ? 'selected' : '' %>>Campeche</option>
                <option value="Chiapas" <%= empleado.Entidad_Federativa === 'Chiapas' ? 'selected' : '' %>>Chiapas</option>
                <option value="Chihuahua" <%= empleado.Entidad_Federativa === 'Chihuahua' ? 'selected' : '' %>>Chihuahua</option>
                <option value="Ciudad de México" <%= empleado.Entidad_Federativa === 'Ciudad de México' ? 'selected' : '' %>>Ciudad de México</option>
                <option value="Coahuila" <%= empleado.Entidad_Federativa === 'Coahuila' ? 'selected' : '' %>>Coahuila</option>
                <option value="Colima" <%= empleado.Entidad_Federativa === 'Colima' ? 'selected' : '' %>>Colima</option>
                <option value="Durango" <%= empleado.Entidad_Federativa === 'Durango' ? 'selected' : '' %>>Durango</option>
                <option value="Guanajuato" <%= empleado.Entidad_Federativa === 'Guanajuato' ? 'selected' : '' %>>Guanajuato</option>
                <option value="Guerrero" <%= empleado.Entidad_Federativa === 'Guerrero' ? 'selected' : '' %>>Guerrero</option>
                <option value="Hidalgo" <%= empleado.Entidad_Federativa === 'Hidalgo' ? 'selected' : '' %>>Hidalgo</option>
                <option value="Jalisco" <%= empleado.Entidad_Federativa === 'Jalisco' ? 'selected' : '' %>>Jalisco</option>
                <option value="México" <%= empleado.Entidad_Federativa === 'México' ? 'selected' : '' %>>México</option>
                <option value="Michoacán" <%= empleado.Entidad_Federativa === 'Michoacán' ? 'selected' : '' %>>Michoacán</option>
                <option value="Morelos" <%= empleado.Entidad_Federativa === 'Morelos' ? 'selected' : '' %>>Morelos</option>
                <option value="Nayarit" <%= empleado.Entidad_Federativa === 'Nayarit' ? 'selected' : '' %>>Nayarit</option>
                <option value="Nuevo León" <%= empleado.Entidad_Federativa === 'Nuevo León' ? 'selected' : '' %>>Nuevo León</option>
                <option value="Oaxaca" <%= empleado.Entidad_Federativa === 'Oaxaca' ? 'selected' : '' %>>Oaxaca</option>
                <option value="Puebla" <%= empleado.Entidad_Federativa === 'Puebla' ? 'selected' : '' %>>Puebla</option>
                <option value="Querétaro" <%= empleado.Entidad_Federativa === 'Querétaro' ? 'selected' : '' %>>Querétaro</option>
                <option value="Quintana Roo" <%= empleado.Entidad_Federativa === 'Quintana Roo' ? 'selected' : '' %>>Quintana Roo</option>
                <option value="San Luis Potosí" <%= empleado.Entidad_Federativa === 'San Luis Potosí' ? 'selected' : '' %>>San Luis Potosí</option>
                <option value="Sinaloa" <%= empleado.Entidad_Federativa === 'Sinaloa' ? 'selected' : '' %>>Sinaloa</option>
                <option value="Sonora" <%= empleado.Entidad_Federativa === 'Sonora' ? 'selected' : '' %>>Sonora</option>
                <option value="Tabasco" <%= empleado.Entidad_Federativa === 'Tabasco' ? 'selected' : '' %>>Tabasco</option>
                <option value="Tamaulipas" <%= empleado.Entidad_Federativa === 'Tamaulipas' ? 'selected' : '' %>>Tamaulipas</option>
                <option value="Tlaxcala" <%= empleado.Entidad_Federativa === 'Tlaxcala' ? 'selected' : '' %>>Tlaxcala</option>
                <option value="Veracruz" <%= empleado.Entidad_Federativa === 'Veracruz' ? 'selected' : '' %>>Veracruz</option>
                <option value="Yucatán" <%= empleado.Entidad_Federativa === 'Yucatán' ? 'selected' : '' %>>Yucatán</option>
                <option value="Zacatecas" <%= empleado.Entidad_Federativa === 'Zacatecas' ? 'selected' : '' %>>Zacatecas</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Código Postal</label>
              <input type="text" class="form-control" name="Codigo_Postal" value="<%= empleado.Codigo_Postal || '' %>" placeholder="5 dígitos" maxlength="5">
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Información Laboral -->
    <div class="col-lg-6">
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">
            <i class="bi bi-briefcase me-2"></i>
            Información Laboral
          </h5>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Área <span class="text-danger">*</span></label>
              <select class="form-select" name="ID_Area" id="selectArea" required>
                <% areas.forEach(function(a) { %>
                  <option value="<%= a.ID_Area %>" <%= a.ID_Area === empleado.ID_Area ? 'selected' : '' %>><%= a.Nombre_Area %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Puesto <span class="text-danger">*</span></label>
              <select class="form-select" name="ID_Puesto" id="selectPuesto" required>
                <% puestos.forEach(function(p) { %>
                  <option value="<%= p.ID_Puesto %>" data-area="<%= p.ID_Area %>" <%= p.ID_Puesto === empleado.ID_Puesto ? 'selected' : '' %>><%= p.Nombre_Puesto %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Tipo de Horario <span class="text-danger">*</span></label>
              <select class="form-select" name="ID_Tipo_Horario" required>
                <% tiposHorario.forEach(function(t) { %>
                  <option value="<%= t.ID_Tipo_Horario %>" <%= t.ID_Tipo_Horario === empleado.ID_Tipo_Horario ? 'selected' : '' %>><%= t.Nombre_Horario %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Estatus <span class="text-danger">*</span></label>
              <select class="form-select" name="ID_Estatus" required>
                <% estatuses.forEach(function(e) { %>
                  <option value="<%= e.ID_Estatus %>" <%= e.ID_Estatus === empleado.ID_Estatus ? 'selected' : '' %>><%= e.Nombre_Estatus %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Fecha de Ingreso <span class="text-danger">*</span></label>
              <input type="date" class="form-control" name="Fecha_Ingreso" value="<%= new Date(empleado.Fecha_Ingreso).toISOString().split('T')[0] %>" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Fecha de Baja</label>
              <input type="date" class="form-control" name="Fecha_Baja" value="<%= empleado.Fecha_Baja ? new Date(empleado.Fecha_Baja).toISOString().split('T')[0] : '' %>">
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Salarios -->
    <div class="col-lg-6">
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">
            <i class="bi bi-currency-dollar me-2"></i>
            Información Salarial
          </h5>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Salario Mensual</label>
              <div class="input-group">
                <span class="input-group-text">$</span>
                <input type="number" step="0.01" class="form-control" id="salarioMensualEdit" name="Salario_Mensual" 
                       value="<%= empleado.Salario_Mensual || '' %>">
              </div>
              <small class="text-body-secondary">Base para calcular diario y hora</small>
            </div>
            <div class="col-md-6">
              <label class="form-label">Salario Diario</label>
              <div class="input-group">
                <span class="input-group-text">$</span>
                <input type="number" step="0.01" class="form-control" id="salarioDiarioEdit" name="Salario_Diario" 
                       value="<%= empleado.Salario_Diario || '' %>" readonly>
              </div>
              <small class="text-body-secondary">= Mensual / 30</small>
            </div>
            <div class="col-md-6">
              <label class="form-label">Salario por Hora</label>
              <div class="input-group">
                <span class="input-group-text">$</span>
                <input type="number" step="0.01" class="form-control" id="salarioHoraEdit" name="Salario_Hora" 
                       value="<%= empleado.Salario_Hora || '' %>" readonly>
              </div>
              <small class="text-body-secondary">= Diario / 8</small>
            </div>
            <div class="col-md-6">
              <label class="form-label">Horas Semanales</label>
              <input type="number" class="form-control" name="Horas_Semanales_Contratadas" value="<%= empleado.Horas_Semanales_Contratadas || '' %>">
            </div>
          </div>
        </div>
        <script>
          document.getElementById('salarioMensualEdit')?.addEventListener('input', function() {
            const mensual = parseFloat(this.value) || 0;
            const diario = Math.round((mensual / 30) * 100) / 100;
            const hora = Math.round((diario / 8) * 100) / 100;
            document.getElementById('salarioDiarioEdit').value = diario.toFixed(2);
            document.getElementById('salarioHoraEdit').value = hora.toFixed(2);
          });
        </script>
      </div>
    </div>
  </div>
  
  <!-- Botones -->
  <div class="d-flex justify-content-between mt-4">
    <form action="/empleados/<%= empleado.ID_Empleado %>/eliminar" method="POST" class="d-inline" 
          onsubmit="return confirm('¿Estás seguro de eliminar este empleado? Esta acción no se puede deshacer.')">
      <button type="submit" class="btn btn-outline-danger">
        <i class="bi bi-trash me-1"></i> Eliminar
      </button>
    </form>
    <div class="d-flex gap-2">
      <a href="/empleados/<%= empleado.ID_Empleado %>" class="btn btn-outline-secondary">
        <i class="bi bi-x-lg me-1"></i> Cancelar
      </a>
      <button type="submit" class="btn btn-primary">
        <i class="bi bi-check-lg me-1"></i> Guardar Cambios
      </button>
    </div>
  </div>
</form>

