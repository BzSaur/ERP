<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Iniciar Sesión | <%= appName || 'ERP RH' %></title>
  
  <!-- CSS Design System -->
  <link rel="stylesheet" href="/css/variables.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/pages.css">
  
  <!-- Bootstrap Icons (iconografía profesional) -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  
  <!-- Bootstrap JS (solo para validación si es necesario) -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" defer></script>
  
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    html, body {
      height: 100%;
      width: 100%;
    }
  </style>
</head>
<body class="login-page">
  <div class="login-wrapper">
    <div class="login-panel">
      <!-- BRANDING: Identidad del sistema -->
      <div class="login-branding">
        <div class="login-icon-box">
          <img src="/img/logo_ram.png" alt="Logo Empresa" class="login-logo-img">
        </div>
        <h1 class="login-app-name">ERP</h1>
        <p class="login-app-desc">Recursos Humanos</p>
      </div>

      <!-- FORM SECTION: Entrada principal -->
      <div class="login-form-section">
        <div class="login-form-header">
          <h2>Accede a tu cuenta</h2>
          <p>Ingresa tus credenciales corporativas</p>
        </div>

        <!-- Error Alert (solo si error existe y NO está vacío) -->
        <% if (error && error.trim && error.trim().length > 0) { %>
        <div class="alert-error">
          <i class="bi bi-exclamation-circle-fill"></i>
          <span><%= error %></span>
        </div>
        <% } %>

        <!-- Formulario de autenticación -->
        <form action="/auth/login" method="POST" class="login-form" novalidate>
          
          <!-- Email Field -->
          <div class="form-group">
            <label for="email" class="form-label">Correo Electrónico</label>
            <div class="input-wrapper">
              <i class="bi bi-envelope input-prefix"></i>
              <input 
                type="email" 
                class="form-input" 
                id="email" 
                name="email" 
                placeholder="correo@empresa.com"
                value="<%= typeof email !== 'undefined' ? email : '' %>"
                required
                autofocus
              >
            </div>
          </div>

          <!-- Password Field -->
          <div class="form-group">
            <label for="password" class="form-label">Contraseña</label>
            <div class="input-wrapper">
              <i class="bi bi-lock-fill input-prefix"></i>
              <input 
                type="password" 
                class="form-input" 
                id="password" 
                name="password" 
                placeholder="••••••••" 
                required
              >
            </div>
          </div>

          <!-- Acciones secundarias -->
          <div class="form-actions">
            <label class="form-checkbox">
              <input type="checkbox" name="remember">
              <span>Recuérdame</span>
            </label>
            <a href="/auth/forgot" class="form-link">¿Olvidaste la contraseña?</a>
          </div>

          <!-- Submit Button (CTA principal) -->
          <button type="submit" class="btn-submit">
            <span>Iniciar Sesión</span>
            <i class="bi bi-arrow-right"></i>
          </button>
        </form>
      </div>

      <!-- FOOTER: Información legal/corporativa -->
      <div class="login-footer">
        <p>© <%= new Date().getFullYear() %> <%= appName || 'ERP RH' %>. Todos los derechos reservados.</p>
      </div>
    </div>
  </div>
</body>
</html>
