<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Iniciar Sesión | <%= appName || 'VITA' %></title>

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- VITA Design System -->
  <link rel="stylesheet" href="/css/variables.css">
  <link rel="stylesheet" href="/css/pages.css">
</head>
<body
  class="login-page"
  data-logout-success="<%= typeof logoutSuccess !== 'undefined' && logoutSuccess ? 'true' : 'false' %>"
>
  <div class="login-wrapper">
    <div class="login-panel">
      <!-- BRANDING: Left column -->
      <div class="login-branding">
        <div class="login-icon-box">
          <img src="/img/logo_ram.png" alt="Logo Empresa" class="login-logo-img">
        </div>
        <h1 class="login-app-name">VITA</h1>
        <p class="login-app-desc">Recursos Humanos</p>
      </div>

      <!-- FORM: Right column -->
      <div class="login-form-section">
        <div class="login-form-header">
          <h2>Accede a tu cuenta</h2>
          <p>Ingresa tus credenciales corporativas</p>
        </div>

        <% if (error && error.trim && error.trim().length > 0) { %>
        <div class="alert-error">
          <i class="bi bi-exclamation-circle-fill"></i>
          <span><%= error %></span>
        </div>
        <% } %>

        <form action="/auth/login" method="POST" class="login-form" novalidate>
          <div class="form-group">
            <label for="email" class="form-label">Correo Electrónico</label>
            <div class="input-wrapper">
              <i class="bi bi-envelope input-prefix"></i>
              <input
                type="email"
                class="form-input"
                id="email"
                name="email"
                placeholder="correo@empresa.com"
                value="<%= typeof email !== 'undefined' ? email : '' %>"
                required
                autofocus
              >
            </div>
          </div>

          <div class="form-group">
            <label for="password" class="form-label">Contraseña</label>
            <div class="input-wrapper password-wrapper">
              <i class="bi bi-lock-fill input-prefix"></i>
              <input
                type="password"
                class="form-input password-input"
                id="password"
                name="password"
                placeholder="••••••••"
                required
              >
              <button
                type="button"
                class="password-toggle"
                id="togglePassword"
                aria-label="Mostrar contraseña"
              >
                <i class="bi bi-eye" id="togglePasswordIcon"></i>
              </button>
            </div>
          </div>

          <div class="form-actions">
            <label class="form-checkbox">
              <input type="checkbox" name="remember">
              <span>Recuérdame</span>
            </label>
            <a href="/auth/forgot" class="form-link">¿Olvidaste la contraseña?</a>
          </div>

          <button type="submit" class="btn-submit">
            <span>Iniciar Sesión</span>
            <i class="bi bi-arrow-right"></i>
          </button>
        </form>
      </div>

      <!-- FOOTER -->
      <div class="login-footer">
        <p>&copy; <%= new Date().getFullYear() %> <%= appName || 'VITA' %>. Todos los derechos reservados.</p>
      </div>
    </div>
  </div>

  <!-- SweetAlert2 -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

  <!-- App Sweet Alerts -->
  <script src="/js/sweet-alerts.js"></script>

  <script>
    (function () {
      const logoutSuccess = document.body.dataset.logoutSuccess === 'true';
      const passwordInput = document.getElementById('password');
      const togglePassword = document.getElementById('togglePassword');
      const togglePasswordIcon = document.getElementById('togglePasswordIcon');

      if (togglePassword && passwordInput && togglePasswordIcon) {
        togglePassword.addEventListener('click', function () {
          const isPassword = passwordInput.type === 'password';
          passwordInput.type = isPassword ? 'text' : 'password';
          togglePasswordIcon.classList.toggle('bi-eye');
          togglePasswordIcon.classList.toggle('bi-eye-slash');
          togglePassword.setAttribute(
            'aria-label',
            isPassword ? 'Ocultar contraseña' : 'Mostrar contraseña'
          );
        });
      }

      if (logoutSuccess && window.AppAlerts) {
        window.AppAlerts.success('Gracias, vuelva pronto', 'Sesión cerrada correctamente.');
      }
    })();
  </script>
</body>
</html>