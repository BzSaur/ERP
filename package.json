{
  "name": "erp-rh",
  "version": "1.0.0",
  "description": "Sistema ERP de Recursos Humanos",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "node prisma/seed.js",
    "seed:catalogos": "node prisma/seed-catalogos.js",
    "seed:config": "node prisma/seed-configuracion.js",
    "seed:all": "npm run seed && npm run seed:catalogos && npm run seed:config",

    "vita:up": "docker compose up -d",
    "vita:up:seed": "cross-env RUN_SEED=true docker compose up -d",
    "vita:down": "docker compose down",
    "vita:restart": "docker compose restart",
    "vita:logs": "docker compose logs -f",
    "vita:logs:app": "docker logs -f erp_rh_app",
    "vita:rebuild": "docker compose up -d --build --no-deps app",
    "vita:deploy": "git pull origin main && npm run vita:rebuild",
    "vita:migrate": "docker exec erp_rh_app npx prisma migrate deploy",
    "vita:seed": "docker exec erp_rh_app node prisma/seed.js",
    "vita:backup": "docker exec erp_rh_postgres pg_dump -U erp_user erp_rh | gzip > backups/erp_rh_backup.sql.gz"
  },
  "keywords": [
    "ERP",
    "RH",
    "Recursos Humanos"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "bcryptjs": "^2.4.3",
    "connect-flash": "^0.1.1",
    "cookie-parser": "^1.4.6",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0",
    "method-override": "^3.0.0",
    "multer": "^2.0.2",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pg": "^8.11.3",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "xlsx": "^0.18.5"
  },
  "prisma": {
    "seed": "node prisma/seed.js && node prisma/seed-catalogos.js && node prisma/seed-configuracion.js"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "prisma": "^5.7.0"
  }
}
